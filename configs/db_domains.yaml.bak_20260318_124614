# 数据库业务主题配置
database:
  name: highway_db
  description: highway_db 是一个面向高速公路服务区全生命周期运营管理的业务分析型数据库，覆盖服务区基础资产、所属公司与组织架构、路段与路线拓扑关系、车流与客流统计、多渠道经营数据（餐饮及零售分支）、跨系统服务标识映射、主题元数据治理以及用户查询反馈闭环等核心场景，支撑经营分析、资源调度、服务质量评估和智能SQL训练等关键业务。
llm_inference:
  max_domains_per_table: 3
domains:
- name: _未分类_
  description: 无法归入其他业务主题的表
  tables:
  - highway_db.public.qa_feedback
- name: 服务区基础资产与组织管理
  description: 管理高速公路服务区实体资产及其归属关系，包括服务区基本信息、所属公司、组织架构及审计元数据
  tables:
  - highway_db.public.bss_service_area
  - highway_db.public.bss_company
- name: 路段-路线-服务区拓扑关系
  description: 刻画高速公路基础设施层级结构，定义路段、路线与服务区之间的空间与逻辑隶属关系
  tables:
  - highway_db.public.bss_section_route
  - highway_db.public.bss_section_route_area_link
- name: 服务区分支网点运营
  description: 记录服务区内部细分业务单元（如餐饮、便利店等分支网点）的静态信息与动态经营表现
  tables:
  - highway_db.public.bss_branch
  - highway_db.public.bss_business_day_data
- name: 交通流量与车型分析
  description: 按日统计进入各服务区的车辆类型分布与使用频次，支撑服务区承载力评估与设施规划
  tables:
  - highway_db.public.bss_car_day_count
- name: 跨系统服务标识治理
  description: 维护服务区在不同业务系统中的命名、编码及唯一标识映射关系，保障主数据一致性与系统集成
  tables:
  - highway_db.public.bss_service_area_mapper
- name: 业务分析主题元数据
  description: 定义高速公路领域可分析的主题域、关联数据表、典型业务问题及关键词，支撑自助分析与语义层建设
  tables:
  - highway_db.public.highway_metadata

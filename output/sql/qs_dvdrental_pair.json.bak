[
  {
    "question": "统计每个国家的城市数量，并按城市数量降序排列，只显示城市数量超过50个的国家",
    "sql": "SELECT co.country AS 国家名称, COUNT(ci.city_id) AS 城市数量 FROM public.country co JOIN public.city ci ON co.country_id = ci.country_id GROUP BY co.country_id, co.country HAVING COUNT(ci.city_id) > 50 ORDER BY 城市数量 DESC;",
    "domain": "_未分类_"
  },
  {
    "question": "列出所有演员参演电影数量最多的前10位演员姓名（全名），并标注其参演影片数",
    "sql": "SELECT a.first_name || ' ' || a.last_name AS 演员全名, COUNT(fa.film_id) AS 参演影片数 FROM public.actor a JOIN public.film_actor fa ON a.actor_id = fa.actor_id GROUP BY a.actor_id, a.first_name, a.last_name ORDER BY 参演影片数 DESC LIMIT 10;",
    "domain": "_未分类_"
  },
  {
    "question": "查询2006年2月15日当天所有门店的租赁订单总数、总支付金额及平均单笔支付金额（需关联rental和payment表）",
    "sql": "SELECT s.store_id AS 门店编号, COUNT(r.rental_id) AS 租赁订单总数, COALESCE(SUM(p.amount), 0) AS 总支付金额, COALESCE(AVG(p.amount), 0) AS 平均单笔支付金额 FROM public.store s LEFT JOIN public.inventory i ON s.store_id = i.store_id LEFT JOIN public.rental r ON i.inventory_id = r.inventory_id LEFT JOIN public.payment p ON r.rental_id = p.rental_id WHERE DATE(r.rental_date) = '2006-02-15' GROUP BY s.store_id ORDER BY 门店编号;",
    "domain": "_未分类_"
  },
  {
    "question": "查询所有活跃客户（active=1）的姓名、邮箱及所属城市名称，按客户姓氏升序排列",
    "sql": "SELECT c.first_name AS 姓名, c.email AS 邮箱, ci.city AS 城市名称 FROM public.customer c JOIN public.address a ON c.address_id = a.address_id JOIN public.city ci ON a.city_id = ci.city_id WHERE c.active = 1 ORDER BY c.last_name ASC;",
    "domain": "客户与账户管理"
  },
  {
    "question": "统计每个国家的客户总数，并按数量降序排列，仅显示客户数超过50的国家",
    "sql": "SELECT co.country AS 国家名称, COUNT(c.customer_id) AS 客户总数 FROM public.customer c JOIN public.address a ON c.address_id = a.address_id JOIN public.city ci ON a.city_id = ci.city_id JOIN public.country co ON ci.country_id = co.country_id GROUP BY co.country HAVING COUNT(c.customer_id) > 50 ORDER BY 客户总数 DESC;",
    "domain": "客户与账户管理"
  },
  {
    "question": "找出创建时间最早（create_date最小）的前5位客户，返回其ID、姓名、邮箱和创建日期",
    "sql": "SELECT customer_id AS 客户ID, first_name AS 名字, last_name AS 姓氏, email AS 邮箱, create_date AS 创建日期 FROM public.customer ORDER BY create_date ASC LIMIT 5;",
    "domain": "客户与账户管理"
  },
  {
    "question": "对比各门店（store_id）的活跃客户数与非活跃客户数，结果包含门店ID、活跃客户数、非活跃客户数",
    "sql": "SELECT store_id AS 门店ID, COUNT(CASE WHEN active = 1 THEN 1 END) AS 活跃客户数, COUNT(CASE WHEN active = 0 THEN 1 END) AS 非活跃客户数 FROM public.customer GROUP BY store_id;",
    "domain": "客户与账户管理"
  },
  {
    "question": "查询所有邮箱以'sakilacustomer.org'结尾且账户已启用（activebool=true）的客户，返回全名、邮箱和所在行政区（district）",
    "sql": "SELECT c.first_name || ' ' || c.last_name AS 全名, c.email AS 邮箱, a.district AS 行政区 FROM public.customer c JOIN public.address a ON c.address_id = a.address_id WHERE c.email LIKE '%@sakilacustomer.org' AND c.activebool = true;",
    "domain": "客户与账户管理"
  },
  {
    "question": "统计每个城市的客户数量，并筛选出客户数最多的前10个城市及其所属国家",
    "sql": "SELECT ci.city AS 城市名称, co.country AS 国家名称, COUNT(c.customer_id) AS 客户数量 FROM public.customer c JOIN public.address a ON c.address_id = a.address_id JOIN public.city ci ON a.city_id = ci.city_id JOIN public.country co ON ci.country_id = co.country_id GROUP BY ci.city, co.country ORDER BY 客户数量 DESC LIMIT 10;",
    "domain": "客户与账户管理"
  },
  {
    "question": "查找2006年创建的所有客户中，姓氏（last_name）出现次数超过3次的姓氏及其出现频次",
    "sql": "SELECT last_name AS 姓氏, COUNT(*) AS 出现次数 FROM public.customer WHERE EXTRACT(YEAR FROM create_date) = 2006 GROUP BY last_name HAVING COUNT(*) > 3 ORDER BY 出现次数 DESC;",
    "domain": "客户与账户管理"
  },
  {
    "question": "列出所有电话号码不为空的客户地址信息，包括客户姓名、联系电话、详细地址和城市名称，按城市升序、联系电话降序排列",
    "sql": "SELECT c.first_name AS 名字, c.last_name AS 姓氏, a.phone AS 联系电话, a.address AS 详细地址, ci.city AS 城市名称 FROM public.customer c JOIN public.address a ON c.address_id = a.address_id JOIN public.city ci ON a.city_id = ci.city_id WHERE a.phone IS NOT NULL AND a.phone != '' ORDER BY ci.city ASC, a.phone DESC;",
    "domain": "客户与账户管理"
  },
  {
    "question": "计算各行政区（district）内活跃客户（active=1）的平均创建年限（按当前日期计算），仅保留平均年限大于5年的行政区",
    "sql": "SELECT a.district AS 行政区, ROUND(AVG(EXTRACT(YEAR FROM AGE(CURRENT_DATE, c.create_date))), 1) AS 平均创建年限 FROM public.customer c JOIN public.address a ON c.address_id = a.address_id WHERE c.active = 1 GROUP BY a.district HAVING AVG(EXTRACT(YEAR FROM AGE(CURRENT_DATE, c.create_date))) > 5;",
    "domain": "客户与账户管理"
  },
  {
    "question": "找出在Alberta行政区且所属门店为1的所有客户，返回客户ID、全名、邮箱、电话及创建日期，并按创建日期倒序排列",
    "sql": "SELECT c.customer_id AS 客户ID, c.first_name || ' ' || c.last_name AS 全名, c.email AS 邮箱, a.phone AS 电话, c.create_date AS 创建日期 FROM public.customer c JOIN public.address a ON c.address_id = a.address_id WHERE a.district = 'Alberta' AND c.store_id = 1 ORDER BY c.create_date DESC;",
    "domain": "客户与账户管理"
  },
  {
    "question": "列出所有门店的详细信息，包括门店ID、经理姓名、所在城市和国家名称，并按国家和城市排序",
    "sql": "SELECT s.store_id AS 门店ID, CONCAT(m.first_name, ' ', m.last_name) AS 经理姓名, c.city AS 城市, co.country AS 国家 FROM public.store s JOIN public.staff m ON s.manager_staff_id = m.staff_id JOIN public.address a ON s.address_id = a.address_id JOIN public.city c ON a.city_id = c.city_id JOIN public.country co ON c.country_id = co.country_id ORDER BY co.country, c.city;",
    "domain": "门店与组织架构"
  },
  {
    "question": "统计每个国家下有多少家门店，并仅显示门店数量大于1的国家，按数量降序排列",
    "sql": "SELECT co.country AS 国家, COUNT(s.store_id) AS 门店数量 FROM public.store s JOIN public.address a ON s.address_id = a.address_id JOIN public.city c ON a.city_id = c.city_id JOIN public.country co ON c.country_id = co.country_id GROUP BY co.country HAVING COUNT(s.store_id) > 1 ORDER BY 门店数量 DESC;",
    "domain": "门店与组织架构"
  },
  {
    "question": "查询所有在职员工所在的门店信息，返回门店ID、员工姓名、邮箱及门店所在城市，结果按门店ID和员工姓氏排序",
    "sql": "SELECT s.store_id AS 门店ID, CONCAT(st.first_name, ' ', st.last_name) AS 员工姓名, st.email AS 邮箱, ci.city AS 城市 FROM public.staff st JOIN public.store s ON st.store_id = s.store_id JOIN public.address a ON s.address_id = a.address_id JOIN public.city ci ON a.city_id = ci.city_id WHERE st.active = true ORDER BY s.store_id, st.last_name;",
    "domain": "门店与组织架构"
  },
  {
    "question": "找出没有分配任何员工的门店（即store_id不在staff表的store_id中），返回门店ID和地址详情",
    "sql": "SELECT s.store_id AS 门店ID, a.address AS 详细地址, a.district AS 行政区, ci.city AS 城市, co.country AS 国家 FROM public.store s JOIN public.address a ON s.address_id = a.address_id JOIN public.city ci ON a.city_id = ci.city_id JOIN public.country co ON ci.country_id = co.country_id WHERE s.store_id NOT IN (SELECT DISTINCT store_id FROM public.staff WHERE store_id IS NOT NULL);",
    "domain": "门店与组织架构"
  },
  {
    "question": "按行政区（district）分组统计各区域内的门店数量，并筛选出门店数最多的前3个行政区",
    "sql": "SELECT a.district AS 行政区, COUNT(s.store_id) AS 门店数量 FROM public.store s JOIN public.address a ON s.address_id = a.address_id GROUP BY a.district ORDER BY 门店数量 DESC LIMIT 3;",
    "domain": "门店与组织架构"
  },
  {
    "question": "查询每位门店经理的姓名、所属门店ID、管理门店的地址及所在城市，并标记该经理是否同时是其所在门店的员工（即manager_staff_id等于该门店下任一staff_id）",
    "sql": "SELECT CONCAT(m.first_name, ' ', m.last_name) AS 经理姓名, s.store_id AS 门店ID, a.address AS 地址, ci.city AS 城市, CASE WHEN EXISTS (SELECT 1 FROM public.staff st WHERE st.staff_id = s.manager_staff_id AND st.store_id = s.store_id) THEN '是' ELSE '否' END AS 是否为本店员工 FROM public.store s JOIN public.staff m ON s.manager_staff_id = m.staff_id JOIN public.address a ON s.address_id = a.address_id JOIN public.city ci ON a.city_id = ci.city_id;",
    "domain": "门店与组织架构"
  },
  {
    "question": "对比各门店的员工总数与在职员工数，计算在职率（在职员工数/总员工数），只显示员工总数不少于2的门店，并按在职率降序排列",
    "sql": "SELECT s.store_id AS 门店ID, COUNT(st.staff_id) AS 总员工数, COUNT(CASE WHEN st.active THEN 1 END) AS 在职员工数, ROUND(COUNT(CASE WHEN st.active THEN 1 END)::DECIMAL / NULLIF(COUNT(st.staff_id), 0), 3) AS 在职率 FROM public.store s LEFT JOIN public.staff st ON s.store_id = st.store_id GROUP BY s.store_id HAVING COUNT(st.staff_id) >= 2 ORDER BY 在职率 DESC;",
    "domain": "门店与组织架构"
  },
  {
    "question": "列出所有门店经理及其直管员工人数（即同一门店下除经理外的其他员工数量），按员工人数降序排列，仅显示有下属员工的经理",
    "sql": "SELECT CONCAT(m.first_name, ' ', m.last_name) AS 经理姓名, s.store_id AS 门店ID, COUNT(st.staff_id) - 1 AS 下属员工数 FROM public.store s JOIN public.staff m ON s.manager_staff_id = m.staff_id JOIN public.staff st ON s.store_id = st.store_id GROUP BY s.store_id, m.first_name, m.last_name HAVING COUNT(st.staff_id) > 1 ORDER BY 下属员工数 DESC;",
    "domain": "门店与组织架构"
  },
  {
    "question": "查询最近一个月内更新过的门店信息，包括门店ID、经理姓名、地址、城市和最后更新时间，并按更新时间倒序排列",
    "sql": "SELECT s.store_id AS 门店ID, CONCAT(m.first_name, ' ', m.last_name) AS 经理姓名, a.address AS 地址, ci.city AS 城市, s.last_update AS 最后更新时间 FROM public.store s JOIN public.staff m ON s.manager_staff_id = m.staff_id JOIN public.address a ON s.address_id = a.address_id JOIN public.city ci ON a.city_id = ci.city_id WHERE s.last_update >= CURRENT_TIMESTAMP - INTERVAL '1 month' ORDER BY s.last_update DESC;",
    "domain": "门店与组织架构"
  },
  {
    "question": "统计每个城市的门店数量和平均员工数（按该城市所有门店的员工总数/门店数），仅显示门店数大于0的城市，并按门店数量降序排列",
    "sql": "SELECT ci.city AS 城市, COUNT(DISTINCT s.store_id) AS 门店数量, ROUND(COUNT(st.staff_id)::DECIMAL / NULLIF(COUNT(DISTINCT s.store_id), 0), 1) AS 平均员工数 FROM public.city ci JOIN public.address a ON ci.city_id = a.city_id JOIN public.store s ON a.address_id = s.address_id LEFT JOIN public.staff st ON s.store_id = st.store_id GROUP BY ci.city_id, ci.city HAVING COUNT(DISTINCT s.store_id) > 0 ORDER BY 门店数量 DESC;",
    "domain": "门店与组织架构"
  },
  {
    "question": "列出所有电影的标题、上映年份、时长（分钟）和租赁单价，并按上映年份降序、标题升序排列",
    "sql": "SELECT title AS 标题, release_year AS 上映年份, length AS 时长分钟, rental_rate AS 租赁单价 FROM public.film ORDER BY release_year DESC, title ASC;",
    "domain": "影片资产与内容管理"
  },
  {
    "question": "统计每个电影分类下的影片数量，并只显示影片数超过50部的分类，按数量降序排列",
    "sql": "SELECT c.name AS 分类名称, COUNT(fc.film_id) AS 影片数量 FROM public.category c JOIN public.film_category fc ON c.category_id = fc.category_id GROUP BY c.category_id, c.name HAVING COUNT(fc.film_id) > 50 ORDER BY 影片数量 DESC;",
    "domain": "影片资产与内容管理"
  },
  {
    "question": "查询所有由演员'Nick Wahlberg'参演且评级为'PG-13'的电影标题、上映年份和评级",
    "sql": "SELECT f.title AS 标题, f.release_year AS 上映年份, f.rating AS 评级 FROM public.film f JOIN public.film_actor fa ON f.film_id = fa.film_id JOIN public.actor a ON fa.actor_id = a.actor_id WHERE a.first_name = 'Nick' AND a.last_name = 'Wahlberg' AND f.rating = 'PG-13';",
    "domain": "影片资产与内容管理"
  },
  {
    "question": "找出租赁单价最高和最低的电影各一部，返回其标题、租赁单价和评级",
    "sql": "SELECT title AS 标题, rental_rate AS 租赁单价, rating AS 评级 FROM public.film WHERE rental_rate = (SELECT MAX(rental_rate) FROM public.film) UNION ALL SELECT title AS 标题, rental_rate AS 租赁单价, rating AS 评级 FROM public.film WHERE rental_rate = (SELECT MIN(rental_rate) FROM public.film);",
    "domain": "影片资产与内容管理"
  },
  {
    "question": "计算每种语言下所有电影的平均时长、总影片数及平均赔偿成本，并按平均时长降序排列",
    "sql": "SELECT l.name AS 语言名称, AVG(f.length) AS 平均时长分钟, COUNT(f.film_id) AS 总影片数, AVG(f.replacement_cost) AS 平均赔偿成本 FROM public.film f JOIN public.language l ON f.language_id = l.language_id GROUP BY l.language_id, l.name ORDER BY 平均时长分钟 DESC;",
    "domain": "影片资产与内容管理"
  },
  {
    "question": "找出同时属于'Action'和'Comedy'两个分类的所有电影标题及上映年份",
    "sql": "SELECT f.title AS 标题, f.release_year AS 上映年份 FROM public.film f JOIN public.film_category fc1 ON f.film_id = fc1.film_id JOIN public.category c1 ON fc1.category_id = c1.category_id JOIN public.film_category fc2 ON f.film_id = fc2.film_id JOIN public.category c2 ON fc2.category_id = c2.category_id WHERE c1.name = 'Action' AND c2.name = 'Comedy';",
    "domain": "影片资产与内容管理"
  },
  {
    "question": "统计每个评级（rating）下影片的平均租金、平均赔偿成本及影片总数，并筛选出影片总数不少于30部的评级",
    "sql": "SELECT rating AS 评级, AVG(rental_rate) AS 平均租金, AVG(replacement_cost) AS 平均赔偿成本, COUNT(*) AS 影片总数 FROM public.film GROUP BY rating HAVING COUNT(*) >= 30 ORDER BY 影片总数 DESC;",
    "domain": "影片资产与内容管理"
  },
  {
    "question": "检索描述中包含'robot'或'battle'关键词（不区分大小写）的前10部电影标题、描述摘要（截取前60字符）和评级",
    "sql": "SELECT title AS 标题, SUBSTRING(description FROM 1 FOR 60) AS 描述摘要, rating AS 评级 FROM public.film WHERE description ILIKE '%robot%' OR description ILIKE '%battle%' LIMIT 10;",
    "domain": "影片资产与内容管理"
  },
  {
    "question": "对比英语和法语影片的分布情况：分别统计两种语言的影片总数、平均租赁时长和最晚上映年份",
    "sql": "SELECT l.name AS 语言名称, COUNT(f.film_id) AS 影片总数, AVG(f.rental_duration) AS 平均租赁时长天数, MAX(f.release_year) AS 最晚上映年份 FROM public.film f JOIN public.language l ON f.language_id = l.language_id WHERE l.name IN ('English', 'French') GROUP BY l.language_id, l.name;",
    "domain": "影片资产与内容管理"
  },
  {
    "question": "列出参演电影数量最多的前5位演员姓名（全名）、参演影片数，以及他们参演影片的平均租赁单价",
    "sql": "SELECT a.first_name || ' ' || a.last_name AS 演员全名, COUNT(fa.film_id) AS 参演影片数, AVG(f.rental_rate) AS 平均租赁单价 FROM public.actor a JOIN public.film_actor fa ON a.actor_id = fa.actor_id JOIN public.film f ON fa.film_id = f.film_id GROUP BY a.actor_id, a.first_name, a.last_name ORDER BY 参演影片数 DESC LIMIT 5;",
    "domain": "影片资产与内容管理"
  },
  {
    "question": "统计每个门店当前未归还的租赁订单数量，并按数量降序排列",
    "sql": "SELECT s.store_id AS 门店ID, COUNT(r.rental_id) AS 未归还订单数 FROM public.store s JOIN public.inventory i ON s.store_id = i.store_id JOIN public.rental r ON i.inventory_id = r.inventory_id WHERE r.return_date IS NULL GROUP BY s.store_id ORDER BY 未归还订单数 DESC;",
    "domain": "库存与租赁运营"
  },
  {
    "question": "查询2005年6月所有已完成归还的租赁记录，包含客户姓名、影片标题、租借日期和归还日期",
    "sql": "SELECT c.first_name || ' ' || c.last_name AS 客户姓名, f.title AS 影片标题, r.rental_date AS 租借日期, r.return_date AS 归还日期 FROM public.rental r JOIN public.customer c ON r.customer_id = c.customer_id JOIN public.inventory i ON r.inventory_id = i.inventory_id JOIN public.film f ON i.film_id = f.film_id WHERE r.return_date IS NOT NULL AND EXTRACT(YEAR FROM r.rental_date) = 2005 AND EXTRACT(MONTH FROM r.rental_date) = 6;",
    "domain": "库存与租赁运营"
  },
  {
    "question": "找出库存中尚未被任何租赁记录关联的影片库存条目（即从未被租出过的库存）",
    "sql": "SELECT i.inventory_id AS 库存ID, f.title AS 影片标题, s.store_id AS 门店ID FROM public.inventory i JOIN public.film f ON i.film_id = f.film_id JOIN public.store s ON i.store_id = s.store_id LEFT JOIN public.rental r ON i.inventory_id = r.inventory_id WHERE r.rental_id IS NULL;",
    "domain": "库存与租赁运营"
  },
  {
    "question": "计算每部影片在所有门店的总库存量，并筛选出总库存大于5的影片，按库存量降序排列",
    "sql": "SELECT f.film_id AS 影片ID, f.title AS 影片标题, COUNT(i.inventory_id) AS 总库存量 FROM public.film f JOIN public.inventory i ON f.film_id = i.film_id GROUP BY f.film_id, f.title HAVING COUNT(i.inventory_id) > 5 ORDER BY 总库存量 DESC;",
    "domain": "库存与租赁运营"
  },
  {
    "question": "分析各门店在2005年5月的租赁活跃度：统计每家门店当月租赁订单总数及平均租赁时长（天）",
    "sql": "SELECT s.store_id AS 门店ID, COUNT(r.rental_id) AS 当月订单数, ROUND(AVG(EXTRACT(EPOCH FROM (r.return_date - r.rental_date)) / 86400), 1) AS 平均租赁时长_天 FROM public.store s JOIN public.inventory i ON s.store_id = i.store_id JOIN public.rental r ON i.inventory_id = r.inventory_id WHERE EXTRACT(YEAR FROM r.rental_date) = 2005 AND EXTRACT(MONTH FROM r.rental_date) = 5 AND r.return_date IS NOT NULL GROUP BY s.store_id ORDER BY 当月订单数 DESC;",
    "domain": "库存与租赁运营"
  },
  {
    "question": "列出被租借次数最多的前10部影片名称及其租借总次数",
    "sql": "SELECT f.title AS 影片标题, COUNT(r.rental_id) AS 租借次数 FROM public.film f JOIN public.inventory i ON f.film_id = i.film_id JOIN public.rental r ON i.inventory_id = r.inventory_id GROUP BY f.film_id, f.title ORDER BY 租借次数 DESC LIMIT 10;",
    "domain": "库存与租赁运营"
  },
  {
    "question": "对比两家指定门店（store_id=1和store_id=2）的库存总量与已租出量，计算各自的库存利用率（已租出/总库存）",
    "sql": "SELECT i.store_id AS 门店ID, COUNT(i.inventory_id) AS 总库存量, COUNT(r.rental_id) AS 已租出量, ROUND(COUNT(r.rental_id)::DECIMAL / NULLIF(COUNT(i.inventory_id), 0), 3) AS 库存利用率 FROM public.inventory i LEFT JOIN public.rental r ON i.inventory_id = r.inventory_id WHERE i.store_id IN (1, 2) GROUP BY i.store_id;",
    "domain": "库存与租赁运营"
  },
  {
    "question": "查询所有在2005年5月24日当天租借且至今仍未归还的租赁记录，返回客户全名、影片标题、租借时间",
    "sql": "SELECT c.first_name || ' ' || c.last_name AS 客户姓名, f.title AS 影片标题, r.rental_date AS 租借时间 FROM public.rental r JOIN public.customer c ON r.customer_id = c.customer_id JOIN public.inventory i ON r.inventory_id = i.inventory_id JOIN public.film f ON i.film_id = f.film_id WHERE DATE(r.rental_date) = '2005-05-24' AND r.return_date IS NULL;",
    "domain": "库存与租赁运营"
  },
  {
    "question": "找出每个门店中库存量最多的一部影片（按inventory_id数量计），返回门店ID、影片ID、影片标题及库存量",
    "sql": "WITH inventory_counts AS (SELECT i.store_id, i.film_id, COUNT(*) AS cnt, ROW_NUMBER() OVER (PARTITION BY i.store_id ORDER BY COUNT(*) DESC) AS rn FROM public.inventory i GROUP BY i.store_id, i.film_id) SELECT ic.store_id AS 门店ID, ic.film_id AS 影片ID, f.title AS 影片标题, ic.cnt AS 库存量 FROM inventory_counts ic JOIN public.film f ON ic.film_id = f.film_id WHERE ic.rn = 1;",
    "domain": "库存与租赁运营"
  },
  {
    "question": "统计每位员工在2005年处理的租赁订单总数，并标注其所属门店，按订单数降序排列，仅显示前5名员工",
    "sql": "SELECT st.staff_id AS 员工ID, st.first_name || ' ' || st.last_name AS 员工姓名, s.store_id AS 所属门店, COUNT(r.rental_id) AS 处理订单数 FROM public.staff st JOIN public.store s ON st.store_id = s.store_id JOIN public.rental r ON st.staff_id = r.staff_id WHERE EXTRACT(YEAR FROM r.rental_date) = 2005 GROUP BY st.staff_id, st.first_name, st.last_name, s.store_id ORDER BY 处理订单数 DESC LIMIT 5;",
    "domain": "库存与租赁运营"
  },
  {
    "question": "查询2007年每月的总支付金额及交易笔数，并按月份升序排列",
    "sql": "SELECT EXTRACT(YEAR FROM payment_date) AS 年份, EXTRACT(MONTH FROM payment_date) AS 月份, SUM(amount) AS 总支付金额, COUNT(*) AS 交易笔数 FROM public.payment WHERE EXTRACT(YEAR FROM payment_date) = 2007 GROUP BY 年份, 月份 ORDER BY 年份, 月份;",
    "domain": "财务与交易管理"
  },
  {
    "question": "找出支付金额最高的前5笔交易，显示客户ID、员工ID、租赁ID、金额和支付时间",
    "sql": "SELECT customer_id AS 客户ID, staff_id AS 员工ID, rental_id AS 租赁ID, amount AS 支付金额, payment_date AS 支付时间 FROM public.payment ORDER BY amount DESC LIMIT 5;",
    "domain": "财务与交易管理"
  },
  {
    "question": "统计每位员工处理的支付总金额和平均单笔金额，仅保留总金额超过1000元的员工",
    "sql": "SELECT staff_id AS 员工ID, SUM(amount) AS 总处理金额, ROUND(AVG(amount), 2) AS 平均单笔金额 FROM public.payment GROUP BY staff_id HAVING SUM(amount) > 1000 ORDER BY 总处理金额 DESC;",
    "domain": "财务与交易管理"
  },
  {
    "question": "列出所有在2007年2月15日当天发生的支付明细，包含客户姓名、员工姓名、金额和支付时间",
    "sql": "SELECT c.first_name || ' ' || c.last_name AS 客户姓名, s.first_name || ' ' || s.last_name AS 员工姓名, p.amount AS 支付金额, p.payment_date AS 支付时间 FROM public.payment p JOIN public.customer c ON p.customer_id = c.customer_id JOIN public.staff s ON p.staff_id = s.staff_id WHERE DATE(p.payment_date) = '2007-02-15' ORDER BY p.payment_date;",
    "domain": "财务与交易管理"
  },
  {
    "question": "计算每个客户的累计支付总额，并按总额降序排列，仅显示前10名高价值客户",
    "sql": "SELECT customer_id AS 客户ID, SUM(amount) AS 累计支付总额 FROM public.payment GROUP BY customer_id ORDER BY 累计支付总额 DESC LIMIT 10;",
    "domain": "财务与交易管理"
  },
  {
    "question": "对比2006年与2007年全年的总支付金额、交易总笔数及平均每笔金额",
    "sql": "SELECT EXTRACT(YEAR FROM payment_date) AS 年份, SUM(amount) AS 总支付金额, COUNT(*) AS 交易总笔数, ROUND(AVG(amount), 2) AS 平均每笔金额 FROM public.payment WHERE EXTRACT(YEAR FROM payment_date) IN (2006, 2007) GROUP BY 年份 ORDER BY 年份;",
    "domain": "财务与交易管理"
  },
  {
    "question": "找出所有金额小于1.00元的异常支付记录，返回支付ID、客户ID、租赁ID、金额和支付时间",
    "sql": "SELECT payment_id AS 支付ID, customer_id AS 客户ID, rental_id AS 租赁ID, amount AS 支付金额, payment_date AS 支付时间 FROM public.payment WHERE amount < 1.00 ORDER BY payment_date;",
    "domain": "财务与交易管理"
  },
  {
    "question": "统计每天的支付笔数和总金额，筛选出日支付总额超过500元的日期，并按日期倒序排列",
    "sql": "SELECT DATE(payment_date) AS 日期, COUNT(*) AS 当日笔数, SUM(amount) AS 当日总金额 FROM public.payment GROUP BY 日期 HAVING SUM(amount) > 500 ORDER BY 日期 DESC;",
    "domain": "财务与交易管理"
  },
  {
    "question": "查询由员工ID为1或2处理的所有支付记录，显示客户全名、影片标题（通过rental→inventory→film关联）、支付金额和时间",
    "sql": "SELECT cu.first_name || ' ' || cu.last_name AS 客户姓名, f.title AS 影片标题, p.amount AS 支付金额, p.payment_date AS 支付时间 FROM public.payment p JOIN public.customer cu ON p.customer_id = cu.customer_id JOIN public.rental r ON p.rental_id = r.rental_id JOIN public.inventory i ON r.inventory_id = i.inventory_id JOIN public.film f ON i.film_id = f.film_id WHERE p.staff_id IN (1, 2) ORDER BY p.payment_date DESC LIMIT 10;",
    "domain": "财务与交易管理"
  },
  {
    "question": "计算每位客户平均每笔支付金额，并找出平均值高于整体平均值的客户列表（含客户ID、姓名、客户平均值、全局平均值）",
    "sql": "WITH global_avg AS (SELECT AVG(amount) AS avg_all FROM public.payment), customer_stats AS (SELECT c.customer_id AS 客户ID, c.first_name || ' ' || c.last_name AS 客户姓名, AVG(p.amount) AS 客户平均支付额 FROM public.payment p JOIN public.customer c ON p.customer_id = c.customer_id GROUP BY c.customer_id, c.first_name, c.last_name) SELECT cs.客户ID, cs.客户姓名, ROUND(cs.客户平均支付额, 2) AS 客户平均值, ROUND(ga.avg_all, 2) AS 全局平均值 FROM customer_stats cs CROSS JOIN global_avg ga WHERE cs.客户平均支付额 > ga.avg_all ORDER BY cs.客户平均支付额 DESC;",
    "domain": "财务与交易管理"
  }
]
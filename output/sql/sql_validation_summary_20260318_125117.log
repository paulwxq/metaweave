   SELECT s.service_area_name AS 服务区名称, br.branch_name AS 档口名称, SUM(b.order_sum) AS 总订单量, AVG(b.pay_sum / NULLIF(b.order_sum, 0)) AS 平均客单价 FROM bss_business_day_data b JOIN bss_branch br ON b.branch_no = br.branch_no JOIN bss_service_area s ON b.service_no = s.service_area_no WHERE br.classify = '餐饮' AND b.oper_date = CURRENT_DATE - INTERVAL '1 day' GROUP BY s.service_area_name, br.branch_name HAVING SUM(b.order_sum) > 100 AND AVG(b.pay_sum / NULLIF(b.order_sum, 0)) > 80;

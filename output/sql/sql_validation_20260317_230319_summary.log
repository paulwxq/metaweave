   SELECT keyword AS "共有关键词", COUNT(*) AS "出现频次" FROM (SELECT UNNEST(k1.keywords) AS keyword FROM public.highway_metadata k1 WHERE k1.topic_code = 'daily_revenue') AS t1 INNER JOIN (SELECT UNNEST(k2.keywords) AS keyword FROM public.highway_metadata k2 WHERE k2.topic_code = 'traffic_volume') AS t2 USING (keyword) GROUP BY keyword;

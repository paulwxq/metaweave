   SELECT a.branch_name AS "档口名称", a.pay_sum AS "4月1日总支付金额", b.pay_sum AS "4月2日总支付金额", COALESCE(b.pay_sum, 0) - COALESCE(a.pay_sum, 0) AS "支付金额差额" FROM public.bss_business_day_data a LEFT JOIN public.bss_business_day_data b ON a.branch_no = b.branch_no AND b.oper_date = '2023-04-02' WHERE a.oper_date = '2023-04-01' AND a.service_name = '庐山服务区';

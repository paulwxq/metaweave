    "sql": "SELECT service_name AS 服务区名称, source_system_type AS 来源系统类型, create_ts AS 创建时间, created_by AS 创建人 FROM public.bss_service_area_mapper WHERE delete_ts IS NULL AND create_ts >= CURRENT_DATE - INTERVAL '7 days' ORDER BY create_ts DESC;",

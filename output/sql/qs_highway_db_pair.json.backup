    "question": "近30天日均营业收入最高的前5个服务区是哪些？",
    "sql": "SELECT s.service_area_name AS 服务区名称, AVG(b.pay_sum) AS 日均营业收入 FROM bss_business_day_data b JOIN bss_service_area s ON b.service_area_id = s.id WHERE b.oper_date >= CURRENT_DATE - INTERVAL '30 days' GROUP BY s.service_area_name ORDER BY 日均营业收入 DESC LIMIT 5;",
    "domain": "业务分析主题元数据"
  },

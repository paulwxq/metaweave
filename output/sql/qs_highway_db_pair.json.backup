    "sql": "SELECT service_name AS 服务区名称, service_no AS 服务区编码, source_system_type AS 来源系统类型, version AS 版本号 FROM public.bss_service_area_mapper WHERE delete_ts IS NULL AND created_by = 'admin' AND version > 1 ORDER BY service_no ASC LIMIT 10;",

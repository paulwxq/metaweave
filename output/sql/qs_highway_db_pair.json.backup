    "sql": "SELECT COUNT(*) AS 记录总数, SUM(customer_count) AS 总车流量, ROUND(AVG(customer_count), 0) AS 平均单日车流量 FROM public.bss_car_day_count WHERE count_date >= '2022-03-01' AND count_date <= '2022-03-31' AND delete_ts IS NULL;",

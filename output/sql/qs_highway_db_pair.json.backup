    "sql": "SELECT DISTINCT service_area_id AS \"服务区ID\" FROM public.bss_car_day_count WHERE count_date = '2022-03-02' AND service_area_id IS NOT NULL;",
    "domain": "交通流量分析"
  },
  {
    "question": "列出所有未被逻辑删除的分公司名称及其编码，并按创建时间降序排列。",
    "sql": "SELECT company_name AS \"分公司名称\", company_no AS \"公司编码\" FROM public.bss_company WHERE delete_ts IS NULL ORDER BY create_ts DESC;",
    "domain": "企业组织结构"
  },
  {
    "question": "统计每个分公司的服务区数量，并按数量从高到低排序，仅显示分公司名称和对应的服务区数量。",
    "sql": "SELECT c.company_name AS \"分公司名称\", COUNT(DISTINCT sa.id) AS \"服务区数量\" FROM public.bss_company c JOIN public.bss_service_area sa ON c.id = sa.company_id WHERE c.delete_ts IS NULL GROUP BY c.id, c.company_name ORDER BY \"服务区数量\" DESC;",
    "domain": "企业组织结构"
  },
  {
    "question": "查询创建于2021年5月20日当天的所有分公司信息，包括分公司名称、编码及创建人。",
    "sql": "SELECT company_name AS \"分公司名称\", company_no AS \"公司编码\", created_by AS \"创建人\" FROM public.bss_company WHERE create_ts >= '2021-05-20 00:00:00' AND create_ts < '2021-05-21 00:00:00';",
    "domain": "企业组织结构"
  },
  {
    "question": "列出所有路段名称及其对应的服务区数量，按服务区数量降序排列。",
    "sql": "SELECT sr.section_name AS \"路段名称\", COUNT(DISTINCT sral.service_area_id) AS \"服务区数量\" FROM public.bss_section_route sr JOIN public.bss_section_route_area_link sral ON sr.id = sral.section_route_id GROUP BY sr.section_name ORDER BY \"服务区数量\" DESC;",
    "domain": "地理信息"
  },
  {
    "question": "查询路线名称为'昌栗'的所有路段所关联的服务区ID列表。",
    "sql": "SELECT sral.service_area_id AS \"服务区ID\" FROM public.bss_section_route sr JOIN public.bss_section_route_area_link sral ON sr.id = sral.section_route_id WHERE sr.route_name = '昌栗';",
    "domain": "地理信息"
  },
  {
    "question": "统计每个路线名称下包含的不同路段数量，并仅显示路段数大于1的路线。",
    "sql": "SELECT sr.route_name AS \"路线名称\", COUNT(DISTINCT sr.section_name) AS \"路段数量\" FROM public.bss_section_route sr GROUP BY sr.route_name HAVING COUNT(DISTINCT sr.section_name) > 1;",
    "domain": "地理信息"
  },
  {
    "question": "列出所有餐饮类档口的名称、品牌、所属服务区方向及合作单位，并按服务区方向排序。",
    "sql": "SELECT branch_name AS \"档口名称\", product_brand AS \"品牌\", direction AS \"服务区方向\", co_company AS \"合作单位\" FROM public.bss_branch WHERE classify = '餐饮' ORDER BY direction;",
    "domain": "餐饮服务"

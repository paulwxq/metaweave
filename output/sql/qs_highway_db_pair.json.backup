    "sql": "SELECT service_name AS 服务区名称 FROM public.bss_service_area_mapper WHERE delete_ts IS NULL AND source_system_type = '驿美' INTERSECT SELECT service_name AS 服务区名称 FROM public.bss_service_area_mapper WHERE delete_ts IS NULL AND source_system_type = '驿购';",

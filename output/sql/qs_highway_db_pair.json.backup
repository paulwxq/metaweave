  {
    "question": "统计每个公司运营的餐饮档口数量，并按数量从高到低排序，仅显示公司ID和档口数量。",
    "sql": "SELECT company_id AS \"公司ID\", COUNT(*) AS \"档口数量\" FROM public.bss_branch WHERE classify = '餐饮' GROUP BY company_id ORDER BY \"档口数量\" DESC;",
    "domain": "餐饮服务"
  },
  {
    "question": "查询位于南区且品牌为“驿美餐饮”的档口明细，包括档口名称、档口编码、所属线路ID和服务区ID。",
    "sql": "SELECT branch_name AS \"档口名称\", branch_no AS \"档口编码\", section_route_id AS \"线路ID\", service_area_id AS \"服务区ID\" FROM public.bss_branch WHERE direction = '南区' AND product_brand = '驿美餐饮';",

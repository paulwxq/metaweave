    "sql": "SELECT service_area_id AS 服务区ID, STRING_AGG(DISTINCT source_system_type, ', ') AS 映射系统类型列表, COUNT(*) AS 映射总数 FROM public.bss_service_area_mapper WHERE delete_ts IS NULL GROUP BY service_area_id HAVING COUNT(*) > 1;",

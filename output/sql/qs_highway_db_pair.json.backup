    "sql": "WITH today AS (SELECT SUM(customer_count) AS total FROM bss_car_day_count WHERE service_area_id = (SELECT id FROM bss_service_area WHERE service_area_name = '鄱阳湖服务区') AND count_date = CURRENT_DATE), yesterday AS (SELECT SUM(customer_count) AS total FROM bss_car_day_count WHERE service_area_id = (SELECT id FROM bss_service_area WHERE service_area_name = '鄱阳湖服务区') AND count_date = CURRENT_DATE - INTERVAL '1 day') SELECT ROUND((t.total::numeric / NULLIF(y.total, 0) - 1) * 100, 2) AS 变化率 FROM today t, yesterday y;",

[
  {
    "question": "查询2023年4月1日各服务区档口的总支付金额排名前10的档口名称、所属服务区名称及总支付金额。",
    "sql": "SELECT branch_name AS \"档口名称\", service_name AS \"服务区名称\", pay_sum AS \"总支付金额\" FROM public.bss_business_day_data WHERE oper_date = '2023-04-01' ORDER BY pay_sum DESC LIMIT 10;",
    "domain": "_未分类_"
  },
  {
    "question": "统计截至2022年3月2日，各车辆类别在所有服务区的总使用数量，并按数量降序排列。",
    "sql": "SELECT car_type AS \"车辆类别\", SUM(customer_count) AS \"总使用数量\" FROM public.bss_car_day_count WHERE count_date = '2022-03-02' GROUP BY car_type ORDER BY \"总使用数量\" DESC;",
    "domain": "_未分类_"
  },
  {
    "question": "列出所有餐饮类档口（classify = '餐饮'）的档口名称、品牌、所属公司名称及服务区名称，要求数据未被逻辑删除。",
    "sql": "SELECT b.branch_name AS \"档口名称\", b.product_brand AS \"品牌\", c.company_name AS \"公司名称\", s.service_area_name AS \"服务区名称\" FROM public.bss_branch b JOIN public.bss_company c ON b.company_id = c.id JOIN public.bss_service_area s ON b.service_area_id = s.id WHERE b.classify = '餐饮' AND b.delete_ts IS NULL AND c.delete_ts IS NULL AND s.delete_ts IS NULL;",
    "domain": "_未分类_"
  },
  {
    "question": "列出所有处于'开放'状态的服务区名称及其对应的公司ID，并按服务区名称排序。",
    "sql": "SELECT service_area_name AS \"服务区名称\", company_id AS \"公司ID\" FROM public.bss_service_area WHERE service_state = '开放' ORDER BY service_area_name;",
    "domain": "服务区管理"
  },
  {
    "question": "查询每个服务区在业务系统中的映射数量，仅统计未被逻辑删除的映射记录，并显示服务区名称和映射数量，按数量降序排列。",
    "sql": "SELECT sa.service_area_name AS \"服务区名称\", COUNT(sam.id) AS \"映射数量\" FROM public.bss_service_area sa JOIN public.bss_service_area_mapper sam ON sa.id = sam.service_area_id WHERE sam.delete_ts IS NULL GROUP BY sa.id, sa.service_area_name ORDER BY \"映射数量\" DESC;",
    "domain": "服务区管理"
  },
  {
    "question": "统计不同来源系统（如驿美、驿购）中服务区编码的唯一数量，并展示来源系统类型及对应的服务区编码去重计数。",
    "sql": "SELECT source_system_type AS \"来源系统类型\", COUNT(DISTINCT service_no) AS \"服务区编码数量\" FROM public.bss_service_area_mapper WHERE delete_ts IS NULL GROUP BY source_system_type;",
    "domain": "服务区管理"
  },
  {
    "question": "查询2023年4月1日各服务区的总支付金额，并按金额从高到低排序，显示前5名服务区名称及其总金额。",
    "sql": "SELECT service_name AS \"服务区名称\", pay_sum AS \"总支付金额\" FROM public.bss_business_day_data WHERE oper_date = '2023-04-01' ORDER BY pay_sum DESC LIMIT 5;",
    "domain": "商业运营"
  },
  {
    "question": "统计2023年4月1日微信支付订单量占当日总订单量比例超过50%的服务区明细，包括服务区名称、档口名称、微信订单量和总订单量。",
    "sql": "SELECT service_name AS \"服务区名称\", branch_name AS \"档口名称\", wx_order AS \"微信订单量\", order_sum AS \"总订单量\" FROM public.bss_business_day_data WHERE oper_date = '2023-04-01' AND order_sum > 0 AND (wx_order::numeric / order_sum) > 0.5;",
    "domain": "商业运营"
  },
  {
    "question": "查询2023年4月1日各档口的现金支付金额及支付宝支付金额，并关联档口信息表（bss_branch）获取档口所属公司编号（假设bss_branch表包含company_no字段），仅返回有现金或支付宝交易的记录。",
    "sql": "SELECT bdd.branch_name AS \"档口名称\", bdd.rmb AS \"现金支付金额\", bdd.zfb AS \"支付宝支付金额\", bb.company_no AS \"公司编号\" FROM public.bss_business_day_data bdd JOIN public.bss_branch bb ON bdd.branch_no = bb.branch_no WHERE bdd.oper_date = '2023-04-01' AND (bdd.rmb > 0 OR bdd.zfb > 0);",
    "domain": "商业运营"
  },
  {
    "question": "2022年3月2日各车型在服务区内使用数量的排名情况如何？",
    "sql": "SELECT car_type AS \"车型\", customer_count AS \"使用数量\" FROM public.bss_car_day_count WHERE count_date = '2022-03-02' ORDER BY customer_count DESC;",
    "domain": "交通流量分析"
  },
  {
    "question": "2022年3月2日所有服务区中，各类车辆的总使用数量是多少？",
    "sql": "SELECT car_type AS \"车型\", SUM(customer_count) AS \"总使用数量\" FROM public.bss_car_day_count WHERE count_date = '2022-03-02' GROUP BY car_type ORDER BY \"总使用数量\" DESC;",
    "domain": "交通流量分析"
  },

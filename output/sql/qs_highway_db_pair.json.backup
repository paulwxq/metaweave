    "sql": "SELECT service_area_id AS 服务区ID, count_date AS 统计日期, customer_count AS 车辆数 FROM public.bss_car_day_count WHERE count_date >= '2022-03-01' AND count_date <= '2022-03-31' AND car_type = '其他' AND delete_ts IS NULL ORDER BY 服务区ID, 统计日期;",

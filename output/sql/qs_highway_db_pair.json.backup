[
  {
    "question": "统计2023年4月1日各服务区的总营收（支付金额合计），按营收从高到低排序，只显示服务区名称和总营收。",
    "sql": "SELECT service_name AS \"服务区名称\", SUM(pay_sum) AS \"总营收\" FROM public.bss_business_day_data WHERE oper_date = '2023-04-01' AND delete_ts IS NULL GROUP BY service_name ORDER BY \"总营收\" DESC;",
    "domain": "_未分类_"
  },
  {
    "question": "查询所有未被逻辑删除的餐饮类档口信息，包括档口名称、档口编码、所属服务区名称、所属公司名称，并按创建时间倒序排列。",
    "sql": "SELECT b.branch_name AS \"档口名称\", b.branch_no AS \"档口编码\", s.service_area_name AS \"服务区名称\", c.company_name AS \"公司名称\" FROM public.bss_branch b JOIN public.bss_service_area s ON b.service_area_id = s.id JOIN public.bss_company c ON b.company_id = c.id WHERE b.classify = '餐饮' AND b.delete_ts IS NULL AND s.delete_ts IS NULL AND c.delete_ts IS NULL ORDER BY b.create_ts DESC;",
    "domain": "_未分类_"
  },
  {
    "question": "列出2022年3月2日车流量超过500辆的服务区名称及其车辆总数，并按车辆数降序排列。",
    "sql": "SELECT sa.service_area_name AS \"服务区名称\", SUM(cd.customer_count) AS \"车辆总数\" FROM public.bss_car_day_count cd JOIN public.bss_service_area sa ON cd.service_area_id = sa.id WHERE cd.count_date = '2022-03-02' AND cd.delete_ts IS NULL AND sa.delete_ts IS NULL GROUP BY sa.service_area_name HAVING SUM(cd.customer_count) > 500 ORDER BY \"车辆总数\" DESC;",
    "domain": "_未分类_"
  },
  {
    "question": "列出所有处于开放状态的服务区名称及其所属公司名称，并按服务区名称升序排列。",
    "sql": "SELECT sa.service_area_name AS \"服务区名称\", c.company_name AS \"所属公司名称\" FROM public.bss_service_area sa JOIN public.bss_company c ON sa.company_id = c.id WHERE sa.service_state = '开放' ORDER BY sa.service_area_name;",
    "domain": "服务区基本信息"
  },
  {
    "question": "统计每个公司名下管理的服务区数量，并按数量降序排列，只显示前5名。",
    "sql": "SELECT c.company_name AS \"公司名称\", COUNT(sa.id) AS \"服务区数量\" FROM public.bss_service_area sa JOIN public.bss_company c ON sa.company_id = c.id WHERE sa.delete_ts IS NULL GROUP BY c.company_name ORDER BY \"服务区数量\" DESC LIMIT 5;",
    "domain": "服务区基本信息"
  },
  {
    "question": "查询名称中包含'服务区'且类型为'信息化服务区'的所有服务区的编号、名称、经纬度及创建时间。",
    "sql": "SELECT service_area_no AS \"服务区编号\", service_area_name AS \"服务区名称\", service_position AS \"经纬度\", create_ts AS \"创建时间\" FROM public.bss_service_area WHERE service_area_name LIKE '%服务区%' AND service_area_type = '信息化服务区' AND delete_ts IS NULL;",
    "domain": "服务区基本信息"
  },
  {
    "question": "请列出2023年4月1日各服务区的微信支付总金额和订单数，并按微信支付金额从高到低排序。",
    "sql": "SELECT service_name AS \"服务区名称\", SUM(wx) AS \"微信支付总金额（元）\", SUM(wx_order) AS \"微信订单总数\" FROM public.bss_business_day_data WHERE oper_date = '2023-04-01' GROUP BY service_name ORDER BY SUM(wx) DESC;",
    "domain": "服务区经营分析"
  },
  {
    "question": "统计2023年4月1日所有档口的现金与支付宝支付金额之和占当日总支付金额的比例，并只显示比例大于10%的档口。",
    "sql": "SELECT branch_name AS \"档口名称\", ROUND((SUM(rmb) + SUM(zfb)) * 100.0 / NULLIF(SUM(pay_sum), 0), 2) AS \"现金与支付宝支付占比（%）\" FROM public.bss_business_day_data WHERE oper_date = '2023-04-01' GROUP BY branch_name HAVING (SUM(rmb) + SUM(zfb)) > 0.1 * SUM(pay_sum);",
    "domain": "服务区经营分析"
  },
  {
    "question": "查询2023年4月1日微信支付金额最高的前5个档口，并关联显示其所属服务区名称。",
    "sql": "SELECT t1.branch_name AS \"档口名称\", t1.service_name AS \"服务区名称\", t1.wx AS \"微信支付金额（元）\" FROM public.bss_business_day_data t1 LEFT JOIN public.bss_service_area_mapper t2 ON t1.service_no = t2.service_no AND t1.service_name = t2.service_name WHERE t1.oper_date = '2023-04-01' ORDER BY t1.wx DESC LIMIT 5;",
    "domain": "服务区经营分析"
  },
  {
    "question": "统计2022年3月2日各车型在所有服务区的车辆总数，并按车辆数量降序排列。",
    "sql": "SELECT car_type AS \"车辆类型\", SUM(customer_count) AS \"车辆总数\" FROM public.bss_car_day_count WHERE count_date = '2022-03-02' AND delete_ts IS NULL GROUP BY car_type ORDER BY \"车辆总数\" DESC;",
    "domain": "车辆流量统计"
  },
  {
    "question": "查询2022年3月2日‘其他’车型在各个服务区的车辆数量，并关联显示服务区名称（来自bss_service_area表）。",
    "sql": "SELECT sa.name AS \"服务区名称\", cdc.customer_count AS \"车辆数量\" FROM public.bss_car_day_count cdc JOIN public.bss_service_area sa ON cdc.service_area_id = sa.id WHERE cdc.count_date = '2022-03-02' AND cdc.car_type = '其他' AND cdc.delete_ts IS NULL AND sa.delete_ts IS NULL;",
    "domain": "车辆流量统计"
  },
  {
    "question": "计算2022年3月每日所有车型的车辆总数，并分析其环比增长情况（与前一日相比）。",
    "sql": "WITH daily_total AS (SELECT count_date AS \"日期\", SUM(customer_count) AS \"当日车辆总数\" FROM public.bss_car_day_count WHERE count_date BETWEEN '2022-03-01' AND '2022-03-31' AND delete_ts IS NULL GROUP BY count_date) SELECT \"日期\", \"当日车辆总数\", ROUND(CAST(\"当日车辆总数\" - LAG(\"当日车辆总数\") OVER (ORDER BY \"日期\") AS NUMERIC) / NULLIF(LAG(\"当日车辆总数\") OVER (ORDER BY \"日期\"), 0) * 100, 2) AS \"环比增长率(%)\" FROM daily_total ORDER BY \"日期\";",
    "domain": "车辆流量统计"
  },
  {
    "question": "列出所有路段名称及其所属路线名称，并按路段名称升序排列。",
    "sql": "SELECT \"路段名称\" AS \"路段名称\", \"路线名称\" AS \"路线名称\" FROM (SELECT section_name AS \"路段名称\", route_name AS \"路线名称\" FROM public.bss_section_route WHERE delete_ts IS NULL ORDER BY section_name ASC) AS t;",
    "domain": "路段与路线管理"
  },
  {
    "question": "统计每条路线关联的服务区数量，并按服务区数量降序排列。",
    "sql": "SELECT r.\"路线名称\", COUNT(l.service_area_id) AS \"服务区数量\" FROM public.bss_section_route r INNER JOIN public.bss_section_route_area_link l ON r.id = l.section_route_id WHERE r.delete_ts IS NULL GROUP BY r.\"路线名称\" ORDER BY \"服务区数量\" DESC;",
    "domain": "路段与路线管理"
  },
  {
    "question": "查询路段名称为'昌栗'的所有服务区名称（需通过路段-路线关联表和服务区关联表联合获取）。",
    "sql": "SELECT sa.\"服务区名称\" FROM public.bss_section_route sr INNER JOIN public.bss_section_route_area_link sral ON sr.id = sral.section_route_id INNER JOIN public.bss_service_area sa ON sral.service_area_id = sa.id WHERE sr.section_name = '昌栗' AND sr.delete_ts IS NULL;",
    "domain": "路段与路线管理"
  },
  {
    "question": "列出所有餐饮类档口的名称、品牌、所属服务区ID及合作单位，并按创建时间倒序排列。",
    "sql": "SELECT branch_name AS \"档口名称\", product_brand AS \"品牌\", service_area_id AS \"服务区ID\", co_company AS \"合作单位\" FROM public.bss_branch WHERE classify = '餐饮' ORDER BY create_ts DESC;",
    "domain": "服务区餐饮及零售"
  },
  {
    "question": "统计每个合作单位下餐饮类档口的数量，并按数量降序排列，仅显示数量大于1的合作单位。",
    "sql": "SELECT co_company AS \"合作单位\", COUNT(*) AS \"餐饮档口数量\" FROM public.bss_branch WHERE classify = '餐饮' GROUP BY co_company HAVING COUNT(*) > 1 ORDER BY \"餐饮档口数量\" DESC;",
    "domain": "服务区餐饮及零售"
  },
  {
    "question": "查询所有手工录入的餐饮档口信息，包括档口名称、编码、方向、品牌及所属公司名称（需关联bss_company表）。",
    "sql": "SELECT b.branch_name AS \"档口名称\", b.branch_no AS \"档口编码\", b.direction AS \"方向\", b.product_brand AS \"品牌\", c.name AS \"公司名称\" FROM public.bss_branch b JOIN public.bss_company c ON b.company_id = c.id WHERE b.is_manual_entry = 1 AND b.classify = '餐饮';",
    "domain": "服务区餐饮及零售"
  },
  {
    "question": "请列出所有属于‘交易分析’大类的主题名称及其对应的关键词。",
    "sql": "SELECT topic_name AS \"主题名称\", keywords AS \"关键词\" FROM public.highway_metadata WHERE theme_tag = '交易分析';",
    "domain": "元数据管理"
  },
  {
    "question": "哪个主题的描述中提到了‘车流量’？请返回其主题编码、中文名称和关联的源数据表。",
    "sql": "SELECT topic_code AS \"主题编码\", topic_name AS \"主题中文名称\", related_tables AS \"关联源数据表\" FROM public.highway_metadata WHERE description ILIKE '%车流量%';",
    "domain": "元数据管理"
  },
  {
    "question": "统计每个主题大类（theme_tag）下包含的主题数量，并按数量降序排列。",
    "sql": "SELECT theme_tag AS \"分析大类\", COUNT(*) AS \"主题数量\" FROM public.highway_metadata GROUP BY theme_tag ORDER BY \"主题数量\" DESC;",
    "domain": "元数据管理"
  },
  {
    "question": "统计每日新增的用户反馈数量，并按日期倒序排列",
    "sql": "SELECT DATE(create_time) AS \"日期\", COUNT(*) AS \"反馈数量\" FROM public.qa_feedback GROUP BY DATE(create_time) ORDER BY DATE(create_time) DESC;",
    "domain": "用户反馈"
  },
  {
    "question": "列出所有被用户点赞且尚未纳入训练数据集的反馈记录，按创建时间降序排列",
    "sql": "SELECT id AS \"反馈ID\", question AS \"问题\", sql AS \"生成SQL\", create_time AS \"创建时间\" FROM public.qa_feedback WHERE is_thumb_up = true AND is_in_training_data = false ORDER BY create_time DESC;",
    "domain": "用户反馈"
  },
  {
    "question": "按用户ID统计其提交的反馈总数、点赞数及未纳入训练的比例",
    "sql": "SELECT user_id AS \"用户ID\", COUNT(*) AS \"总反馈数\", COUNT(*) FILTER (WHERE is_thumb_up = true) AS \"点赞数\", ROUND(COUNT(*) FILTER (WHERE is_in_training_data = false)::DECIMAL / NULLIF(COUNT(*), 0), 4) AS \"未入训比例\" FROM public.qa_feedback GROUP BY user_id ORDER BY \"总反馈数\" DESC;",
    "domain": "用户反馈"
  }
]
[
  {
    "question": "统计近7天每日用户反馈数量，并按日期升序排列",
    "sql": "SELECT DATE(create_time) AS 日期, COUNT(*) AS 反馈数量 FROM qa_feedback WHERE create_time >= CURRENT_DATE - INTERVAL '7 days' GROUP BY DATE(create_time) ORDER BY 日期 ASC;",
    "domain": "_未分类_"
  },
  {
    "question": "列出点赞数最多的前5个自然语言问题及其对应SQL语句",
    "sql": "SELECT question AS 问题, sql AS 生成SQL FROM qa_feedback WHERE is_thumb_up = true ORDER BY create_time DESC LIMIT 5;",
    "domain": "_未分类_"
  },
  {
    "question": "对比分析已纳入训练数据与未纳入训练数据的反馈中，用户点赞率（点赞数/总数）差异",
    "sql": "SELECT is_in_training_data AS 是否在训练集, COUNT(*) AS 总数, COUNT(CASE WHEN is_thumb_up THEN 1 END)::FLOAT / COUNT(*) AS 点赞率 FROM qa_feedback GROUP BY is_in_training_data;",
    "domain": "_未分类_"
  },
  {
    "question": "查询所有未被逻辑删除的服务区名称、编码及其所属公司名称，并按服务区创建时间倒序排列",
    "sql": "SELECT sa.service_area_name AS 服务区名称, sa.service_area_no AS 服务区编码, c.company_name AS 所属公司名称 FROM public.bss_service_area sa JOIN public.bss_company c ON sa.company_id = c.id WHERE sa.delete_ts IS NULL AND c.delete_ts IS NULL ORDER BY sa.create_ts DESC;",
    "domain": "服务区基础资产与组织管理"
  },
  {
    "question": "统计每个公司下辖的服务区数量，并仅显示服务区数量大于5的公司，按数量降序排列",
    "sql": "SELECT c.company_name AS 公司名称, COUNT(sa.id) AS 服务区数量 FROM public.bss_company c LEFT JOIN public.bss_service_area sa ON c.id = sa.company_id AND sa.delete_ts IS NULL WHERE c.delete_ts IS NULL GROUP BY c.id, c.company_name HAVING COUNT(sa.id) > 5 ORDER BY 服务区数量 DESC;",
    "domain": "服务区基础资产与组织管理"
  },
  {
    "question": "列出所有状态为'开放'且类型为'信息化服务区'的服务区，返回其名称、编码、经纬度及所属公司编码",
    "sql": "SELECT sa.service_area_name AS 服务区名称, sa.service_area_no AS 服务区编码, sa.service_position AS 经纬度, c.company_no AS 所属公司编码 FROM public.bss_service_area sa JOIN public.bss_company c ON sa.company_id = c.id WHERE sa.service_state = '开放' AND sa.service_area_type = '信息化服务区' AND sa.delete_ts IS NULL AND c.delete_ts IS NULL;",
    "domain": "服务区基础资产与组织管理"
  },
  {
    "question": "查询创建时间最早和最晚的两个服务区信息（包括名称、编码、创建人和创建时间）",
    "sql": "SELECT service_area_name AS 服务区名称, service_area_no AS 服务区编码, created_by AS 创建人, create_ts AS 创建时间 FROM public.bss_service_area WHERE delete_ts IS NULL ORDER BY create_ts LIMIT 1 UNION ALL SELECT service_area_name AS 服务区名称, service_area_no AS 服务区编码, created_by AS 创建人, create_ts AS 创建时间 FROM public.bss_service_area WHERE delete_ts IS NULL ORDER BY create_ts DESC LIMIT 1;",
    "domain": "服务区基础资产与组织管理"
  },
  {
    "question": "对比各公司所辖服务区的平均版本号（version），筛选出平均版本大于2的公司，并按平均版本降序展示",
    "sql": "SELECT c.company_name AS 公司名称, ROUND(AVG(sa.version), 2) AS 平均数据版本 FROM public.bss_company c JOIN public.bss_service_area sa ON c.id = sa.company_id WHERE c.delete_ts IS NULL AND sa.delete_ts IS NULL GROUP BY c.id, c.company_name HAVING AVG(sa.version) > 2 ORDER BY 平均数据版本 DESC;",
    "domain": "服务区基础资产与组织管理"
  },
  {
    "question": "查询所有在2021年7月之后更新过的服务区明细，包括名称、编码、最后更新人、更新时间及所属公司名称",
    "sql": "SELECT sa.service_area_name AS 服务区名称, sa.service_area_no AS 服务区编码, sa.updated_by AS 最后更新人, sa.update_ts AS 更新时间, c.company_name AS 所属公司名称 FROM public.bss_service_area sa JOIN public.bss_company c ON sa.company_id = c.id WHERE sa.update_ts > '2021-07-01' AND sa.delete_ts IS NULL AND c.delete_ts IS NULL ORDER BY sa.update_ts DESC;",
    "domain": "服务区基础资产与组织管理"
  },
  {
    "question": "找出尚未关联任何公司的服务区（即company_id为空或不匹配bss_company表中有效id的服务区）",
    "sql": "SELECT sa.service_area_name AS 服务区名称, sa.service_area_no AS 服务区编码, sa.company_id AS 公司ID FROM public.bss_service_area sa WHERE sa.company_id IS NULL OR sa.company_id NOT IN (SELECT id FROM public.bss_company WHERE delete_ts IS NULL) AND sa.delete_ts IS NULL;",
    "domain": "服务区基础资产与组织管理"
  },
  {
    "question": "按服务区类型分组统计各类别下的服务区总数、平均创建时间及最新更新时间",
    "sql": "SELECT sa.service_area_type AS 服务区类型, COUNT(*) AS 数量, TO_CHAR(AVG(EXTRACT(EPOCH FROM sa.create_ts)), 'FM999999999') AS 平均创建时间戳秒数, MAX(sa.update_ts) AS 最新更新时间 FROM public.bss_service_area sa WHERE sa.delete_ts IS NULL GROUP BY sa.service_area_type ORDER BY 数量 DESC;",
    "domain": "服务区基础资产与组织管理"
  },
  {
    "question": "查询上饶分公司和宜春分公司各自管理的服务区数量，并以公司名称和数量两列呈现",
    "sql": "SELECT c.company_name AS 公司名称, COUNT(sa.id) AS 管理的服务区数量 FROM public.bss_company c LEFT JOIN public.bss_service_area sa ON c.id = sa.company_id AND sa.delete_ts IS NULL WHERE c.company_name IN ('上饶分公司', '宜春分公司') AND c.delete_ts IS NULL GROUP BY c.company_name;",
    "domain": "服务区基础资产与组织管理"
  },
  {
    "question": "获取最近30天内被逻辑删除的服务区列表，包括名称、编码、删除人、删除时间及所属公司名称",
    "sql": "SELECT sa.service_area_name AS 服务区名称, sa.service_area_no AS 服务区编码, sa.deleted_by AS 删除人, sa.delete_ts AS 删除时间, c.company_name AS 所属公司名称 FROM public.bss_service_area sa JOIN public.bss_company c ON sa.company_id = c.id WHERE sa.delete_ts >= CURRENT_DATE - INTERVAL '30 days' AND sa.delete_ts IS NOT NULL AND c.delete_ts IS NULL ORDER BY sa.delete_ts DESC;",
    "domain": "服务区基础资产与组织管理"
  },
  {
    "question": "查询每个路线所包含的路段数量，并按数量降序排列",
    "sql": "SELECT route_name AS 路线名称, COUNT(*) AS 路段数量 FROM public.bss_section_route WHERE delete_ts IS NULL GROUP BY route_name ORDER BY 路段数量 DESC;",
    "domain": "路段-路线-服务区拓扑关系"
  },
  {
    "question": "找出尚未关联任何服务区的路段路由记录（即在bss_section_route_area_link中无对应section_route_id）",
    "sql": "SELECT sr.id AS 记录ID, sr.section_name AS 路段名称, sr.route_name AS 路线名称 FROM public.bss_section_route sr LEFT JOIN public.bss_section_route_area_link sral ON sr.id = sral.section_route_id WHERE sral.section_route_id IS NULL AND sr.delete_ts IS NULL;",
    "domain": "路段-路线-服务区拓扑关系"
  },
  {
    "question": "统计每个服务区关联的路段-路线组合数量，并筛选出关联数超过2个的服务区",
    "sql": "SELECT sa.id AS 服务区ID, COUNT(sral.section_route_id) AS 关联路段路由数 FROM public.bss_section_route_area_link sral JOIN public.bss_section_route sr ON sral.section_route_id = sr.id JOIN (SELECT DISTINCT id FROM public.bss_service_area) sa ON sral.service_area_id = sa.id WHERE sr.delete_ts IS NULL GROUP BY sa.id HAVING COUNT(sral.section_route_id) > 2;",
    "domain": "路段-路线-服务区拓扑关系"
  },
  {
    "question": "列出昌韶路线下的所有路段名称及其对应的服务区名称（需关联服务区基础表，假设服务区表为public.bss_service_area且含name字段）",
    "sql": "SELECT sr.section_name AS 路段名称, sr.route_name AS 路线名称, sa.name AS 服务区名称 FROM public.bss_section_route sr JOIN public.bss_section_route_area_link sral ON sr.id = sral.section_route_id JOIN public.bss_service_area sa ON sral.service_area_id = sa.id WHERE sr.route_name = '昌韶' AND sr.delete_ts IS NULL;",
    "domain": "路段-路线-服务区拓扑关系"
  },
  {
    "question": "查询2021年10月创建的路段-路线关联记录总数及平均版本号",
    "sql": "SELECT COUNT(*) AS 记录总数, AVG(version) AS 平均版本号 FROM public.bss_section_route WHERE delete_ts IS NULL AND EXTRACT(YEAR FROM create_ts) = 2021 AND EXTRACT(MONTH FROM create_ts) = 10;",
    "domain": "路段-路线-服务区拓扑关系"
  },
  {
    "question": "按路段名称分组，统计各路段所属的不同路线数量，仅显示属于多条路线的路段",
    "sql": "SELECT section_name AS 路段名称, COUNT(DISTINCT route_name) AS 所属路线数 FROM public.bss_section_route WHERE delete_ts IS NULL GROUP BY section_name HAVING COUNT(DISTINCT route_name) > 1;",
    "domain": "路段-路线-服务区拓扑关系"
  },
  {
    "question": "获取编号以'SR00'开头的前5条有效路段-路线记录，按创建时间倒序排列",
    "sql": "SELECT id AS 记录ID, section_name AS 路段名称, route_name AS 路线名称, code AS 编号, create_ts AS 创建时间 FROM public.bss_section_route WHERE code LIKE 'SR00%' AND delete_ts IS NULL ORDER BY create_ts DESC LIMIT 5;",
    "domain": "路段-路线-服务区拓扑关系"
  },
  {
    "question": "对比昌栗路线与昌韶路线各自关联的服务区数量，并以路线名称和数量两列返回",
    "sql": "SELECT route_name AS 路线名称, COUNT(DISTINCT sral.service_area_id) AS 关联服务区数量 FROM public.bss_section_route sr JOIN public.bss_section_route_area_link sral ON sr.id = sral.section_route_id WHERE sr.route_name IN ('昌栗', '昌韶') AND sr.delete_ts IS NULL GROUP BY route_name;",
    "domain": "路段-路线-服务区拓扑关系"
  },
  {
    "question": "查询创建人是admin且未被删除的所有路段-路线记录中，路段名称出现频次最高的前3名",
    "sql": "SELECT section_name AS 路段名称, COUNT(*) AS 出现次数 FROM public.bss_section_route WHERE created_by = 'admin' AND delete_ts IS NULL GROUP BY section_name ORDER BY 出现次数 DESC LIMIT 3;",
    "domain": "路段-路线-服务区拓扑关系"
  },
  {
    "question": "找出同时出现在昌栗路线和昌韶路线中的路段名称（即跨路线路段）",
    "sql": "SELECT section_name AS 跨路线路段名称 FROM public.bss_section_route WHERE delete_ts IS NULL AND route_name IN ('昌栗', '昌韶') GROUP BY section_name HAVING COUNT(DISTINCT route_name) = 2;",
    "domain": "路段-路线-服务区拓扑关系"
  },
  {
    "question": "查询2023年4月1日各餐饮分支网点的微信支付金额、订单数及总支付金额，并按总支付金额降序排列",
    "sql": "SELECT branch_name AS 档口名称, wx AS 微信支付金额, wx_order AS 微信订单数, pay_sum AS 总支付金额 FROM public.bss_business_day_data WHERE oper_date = '2023-04-01' AND branch_no IN (SELECT branch_no FROM public.bss_branch WHERE classify = '餐饮') ORDER BY pay_sum DESC;",
    "domain": "服务区分支网点运营"
  },
  {
    "question": "统计每个服务区方向（如南区、西区）下餐饮类分支网点的数量，并仅显示网点数超过2个的方向",
    "sql": "SELECT direction AS 服务区方向, COUNT(*) AS 餐饮网点数量 FROM public.bss_branch WHERE classify = '餐饮' AND delete_ts IS NULL GROUP BY direction HAVING COUNT(*) > 2;",
    "domain": "服务区分支网点运营"
  },
  {
    "question": "列出所有手工录入的餐饮分支网点信息，包括档口名称、品牌、合作单位及创建时间，按创建时间倒序排列",
    "sql": "SELECT branch_name AS 档口名称, product_brand AS 品牌, co_company AS 合作单位, create_ts AS 创建时间 FROM public.bss_branch WHERE is_manual_entry = 1 AND classify = '餐饮' AND delete_ts IS NULL ORDER BY create_ts DESC;",
    "domain": "服务区分支网点运营"
  },
  {
    "question": "对比2023年4月1日与2023年4月2日庐山服务区各分支网点的总支付金额差异，显示档口名称、两日金额及差额",
    "sql": "SELECT a.branch_name AS 档口名称, a.pay_sum AS 4月1日总支付金额, b.pay_sum AS 4月2日总支付金额, COALESCE(b.pay_sum, 0) - COALESCE(a.pay_sum, 0) AS 支付金额差额 FROM public.bss_business_day_data a LEFT JOIN public.bss_business_day_data b ON a.branch_no = b.branch_no AND b.oper_date = '2023-04-02' WHERE a.oper_date = '2023-04-01' AND a.service_name = '庐山服务区';",
    "domain": "服务区分支网点运营"
  },
  {
    "question": "查询2023年4月全月各餐饮分支网点的日均订单总数和日均总支付金额，按日均支付金额降序取前10名",
    "sql": "SELECT b.branch_name AS 档口名称, AVG(d.order_sum) AS 日均订单总数, AVG(d.pay_sum) AS 日均总支付金额 FROM public.bss_branch b JOIN public.bss_business_day_data d ON b.branch_no = d.branch_no WHERE b.classify = '餐饮' AND b.delete_ts IS NULL AND d.oper_date >= '2023-04-01' AND d.oper_date <= '2023-04-30' GROUP BY b.branch_name ORDER BY AVG(d.pay_sum) DESC LIMIT 10;",
    "domain": "服务区分支网点运营"
  },
  {
    "question": "找出在2023年4月有连续3天以上总支付金额超过5000元的餐饮分支网点名称及其最高单日支付金额",
    "sql": "SELECT branch_name AS 档口名称, MAX(pay_sum) AS 最高单日支付金额 FROM public.bss_business_day_data WHERE branch_no IN (SELECT branch_no FROM public.bss_branch WHERE classify = '餐饮' AND delete_ts IS NULL) AND oper_date >= '2023-04-01' AND oper_date <= '2023-04-30' AND pay_sum > 5000 GROUP BY branch_name HAVING COUNT(*) >= 3;",
    "domain": "服务区分支网点运营"
  },
  {
    "question": "汇总分析2023年4月各支付渠道（微信、支付宝、现金、信用卡、京东）在餐饮分支网点中的总交易金额和总订单数",
    "sql": "SELECT SUM(wx) AS 微信总金额, SUM(zfb) AS 支付宝总金额, SUM(rmb) AS 现金总金额, SUM(xs) AS 信用卡总金额, SUM(jd) AS 京东总金额, SUM(wx_order) AS 微信总订单数, SUM(zf_order) AS 支付宝总订单数, SUM(rmb_order) AS 现金总订单数, SUM(xs_order) AS 信用卡总订单数, SUM(jd_order) AS 京东总订单数 FROM public.bss_business_day_data d JOIN public.bss_branch b ON d.branch_no = b.branch_no WHERE b.classify = '餐饮' AND b.delete_ts IS NULL AND d.oper_date >= '2023-04-01' AND d.oper_date <= '2023-04-30';",
    "domain": "服务区分支网点运营"
  },
  {
    "question": "查询所有未被逻辑删除且属于‘驿美餐饮’品牌的分支网点，展示其档口名称、编码、所属公司ID及服务区ID",
    "sql": "SELECT branch_name AS 档口名称, branch_no AS 档口编码, company_id AS 所属公司ID, service_area_id AS 服务区ID FROM public.bss_branch WHERE product_brand = '驿美餐饮' AND delete_ts IS NULL;",
    "domain": "服务区分支网点运营"
  },
  {
    "question": "统计2023年4月各品类（餐饮、零售等）分支网点的平均单日总支付金额，并按品类分组排序",
    "sql": "SELECT b.classify AS 品类, AVG(d.pay_sum) AS 平均单日总支付金额 FROM public.bss_branch b JOIN public.bss_business_day_data d ON b.branch_no = d.branch_no WHERE b.delete_ts IS NULL AND d.oper_date >= '2023-04-01' AND d.oper_date <= '2023-04-30' GROUP BY b.classify ORDER BY 平均单日总支付金额 DESC;",
    "domain": "服务区分支网点运营"
  },
  {
    "question": "列出2023年4月1日总支付金额排名前5的分支网点详细信息，包括档口名称、编码、品类、品牌、方向及当日支付金额",
    "sql": "SELECT b.branch_name AS 档口名称, b.branch_no AS 档口编码, b.classify AS 品类, b.product_brand AS 品牌, b.direction AS 方向, d.pay_sum AS 当日总支付金额 FROM public.bss_branch b JOIN public.bss_business_day_data d ON b.branch_no = d.branch_no WHERE d.oper_date = '2023-04-01' AND b.delete_ts IS NULL ORDER BY d.pay_sum DESC LIMIT 5;",
    "domain": "服务区分支网点运营"
  },
  {
    "question": "查询2022年3月所有服务区中，各类车型的日均车流量排名前5的车型及其平均车辆数",
    "sql": "SELECT car_type AS 车型, ROUND(AVG(customer_count), 0) AS 日均车辆数 FROM public.bss_car_day_count WHERE count_date >= '2022-03-01' AND count_date <= '2022-03-31' AND delete_ts IS NULL GROUP BY car_type ORDER BY 日均车辆数 DESC LIMIT 5;",
    "domain": "交通流量与车型分析"
  },
  {
    "question": "统计2022年3月2日各服务区的总车流量，并按流量从高到低排序，仅显示前10名",
    "sql": "SELECT service_area_id AS 服务区ID, SUM(customer_count) AS 当日总车流量 FROM public.bss_car_day_count WHERE count_date = '2022-03-02' AND delete_ts IS NULL GROUP BY service_area_id ORDER BY 当日总车流量 DESC LIMIT 10;",
    "domain": "交通流量与车型分析"
  },
  {
    "question": "对比分析2022年3月1日与3月2日‘小型客车’车型在各服务区的车流变化量（差值），仅显示变化量绝对值大于100的服务区",
    "sql": "SELECT a.service_area_id AS 服务区ID, (b.customer_count - a.customer_count) AS 车流变化量 FROM public.bss_car_day_count a JOIN public.bss_car_day_count b ON a.service_area_id = b.service_area_id AND a.car_type = b.car_type WHERE a.count_date = '2022-03-01' AND b.count_date = '2022-03-02' AND a.car_type = '小型客车' AND b.car_type = '小型客车' AND a.delete_ts IS NULL AND b.delete_ts IS NULL HAVING ABS(b.customer_count - a.customer_count) > 100;",
    "domain": "交通流量与车型分析"
  },
  {
    "question": "查询2022年3月期间，每日‘货车’车型在所有服务区的汇总车流量，并按日期升序排列",
    "sql": "SELECT count_date AS 统计日期, SUM(customer_count) AS 货车总车流量 FROM public.bss_car_day_count WHERE count_date >= '2022-03-01' AND count_date <= '2022-03-31' AND car_type = '货车' AND delete_ts IS NULL GROUP BY count_date ORDER BY 统计日期 ASC;",
    "domain": "交通流量与车型分析"
  },
  {
    "question": "列出2022年3月车流量最高的单日记录（含车型、服务区ID、车辆数、统计日期）",
    "sql": "SELECT car_type AS 车型, service_area_id AS 服务区ID, customer_count AS 车辆数, count_date AS 统计日期 FROM public.bss_car_day_count WHERE count_date >= '2022-03-01' AND count_date <= '2022-03-31' AND delete_ts IS NULL ORDER BY customer_count DESC LIMIT 1;",
    "domain": "交通流量与车型分析"
  },
  {
    "question": "统计2022年3月各车型在所有服务区的出现天数（去重统计count_date）及总车流量，按出现天数降序排列",
    "sql": "SELECT car_type AS 车型, COUNT(DISTINCT count_date) AS 出现天数, SUM(customer_count) AS 总车流量 FROM public.bss_car_day_count WHERE count_date >= '2022-03-01' AND count_date <= '2022-03-31' AND delete_ts IS NULL GROUP BY car_type ORDER BY 出现天数 DESC;",
    "domain": "交通流量与车型分析"
  },
  {
    "question": "查询2022年3月‘小型客车’和‘大型客车’两类车型每日车流量之和，并筛选出合计超过5000的日期",
    "sql": "SELECT count_date AS 统计日期, SUM(customer_count) AS 两类客车总车流量 FROM public.bss_car_day_count WHERE count_date >= '2022-03-01' AND count_date <= '2022-03-31' AND car_type IN ('小型客车', '大型客车') AND delete_ts IS NULL GROUP BY count_date HAVING SUM(customer_count) > 5000 ORDER BY 统计日期;",

    "sql": "SELECT (SELECT COUNT(*) FROM public.bss_service_area_mapper WHERE delete_ts IS NULL AND source_system_type = '驿美') - (SELECT COUNT(*) FROM public.bss_service_area_mapper WHERE delete_ts IS NULL AND source_system_type = '驿购') AS 系统映射数量差;",

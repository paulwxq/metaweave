    "sql": "SELECT br.branch_name AS 档口名称, AVG(b.pay_sum / NULLIF(b.order_sum, 0)) AS 平均订单金额 FROM bss_business_day_data b JOIN bss_branch br ON b.branch_id = br.id WHERE br.branch_type = '餐饮' AND b.order_sum > 0 GROUP BY br.branch_name HAVING AVG(b.pay_sum / NULLIF(b.order_sum, 0)) > 200 ORDER BY 平均订单金额 DESC;",

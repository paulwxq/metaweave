    "sql": "SELECT service_name AS 服务区名称, service_no AS 服务区编码, source_system_type AS 来源系统类型, update_ts AS 最后更新时间 FROM public.bss_service_area_mapper WHERE delete_ts IS NULL AND update_ts > '2023-01-15' ORDER BY update_ts DESC;",

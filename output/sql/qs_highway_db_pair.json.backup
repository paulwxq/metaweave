    "sql": "SELECT car_type AS 车型, ROUND(SUM(customer_count) * 100.0 / (SELECT SUM(customer_count) FROM public.bss_car_day_count WHERE count_date >= '2022-03-01' AND count_date <= '2022-03-31' AND delete_ts IS NULL), 2) AS 占比百分比 FROM public.bss_car_day_count WHERE count_date >= '2022-03-01' AND count_date <= '2022-03-31' AND delete_ts IS NULL GROUP BY car_type ORDER BY 占比百分比 DESC;",
    "domain": "交通流量与车型分析"

   SELECT co.country AS "国家", COUNT(*) AS "2006年后更新城市数" FROM public.country co JOIN public.city ci ON co.country_id = ci.country_id WHERE ci.last_update > '2006-01-01' GROUP BY co.country ORDER BY "2006年后更新城市数" DESC;
----------------------------------------


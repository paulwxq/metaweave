                                                              ^
   修复后SQL:
   SELECT c.customer_id AS 客户ID, c.first_name AS 名字, c.last_name AS 姓氏, c.email AS 邮箱, c.address_id AS 地址ID, COALESCE(ci.city, '未知') AS 城市 FROM public.customer c LEFT JOIN public.address a ON c.address_id = a.address_id LEFT JOIN public.city ci ON a.city_id = ci.city_id;
----------------------------------------


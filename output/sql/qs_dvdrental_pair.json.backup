[
  {
    "question": "统计每个国家的城市数量，并按城市数量降序排列，只显示城市数量超过5个的国家",
    "sql": "SELECT co.country AS 国家名称, COUNT(ci.city_id) AS 城市数量 FROM public.country co JOIN public.city ci ON co.country_id = ci.country_id GROUP BY co.country_id, co.country HAVING COUNT(ci.city_id) > 5 ORDER BY 城市数量 DESC;",
    "domain": "_未分类_"
  },
  {
    "question": "查询所有活跃客户中姓氏以'Smi'开头的前10位客户姓名、邮箱及注册日期，并按注册日期倒序排列",
    "sql": "SELECT first_name AS 名字, last_name AS 姓氏, email AS 邮箱, create_date AS 注册日期 FROM public.customer WHERE activebool = true AND last_name LIKE 'Smi%' ORDER BY create_date DESC LIMIT 10;",
    "domain": "_未分类_"
  },
  {
    "question": "列出每部电影的标题、所属分类名称、演员总数，并按演员数量降序排列，取前5部电影",
    "sql": "SELECT f.title AS 电影标题, c.name AS 分类名称, COUNT(DISTINCT fa.actor_id) AS 演员总数 FROM public.film f JOIN public.film_category fc ON f.film_id = fc.film_id JOIN public.category c ON fc.category_id = c.category_id JOIN public.film_actor fa ON f.film_id = fa.film_id GROUP BY f.film_id, f.title, c.name ORDER BY 演员总数 DESC LIMIT 5;",
    "domain": "_未分类_"
  },
  {
    "question": "查询所有活跃客户（activebool为true）的姓名、邮箱和创建日期，并按创建日期降序排列，仅显示前10条记录",
    "sql": "SELECT first_name AS 姓名, last_name AS 姓氏, email AS 邮箱, create_date AS 创建日期 FROM public.customer WHERE activebool = true ORDER BY create_date DESC LIMIT 10;",
    "domain": "客户与账户管理"
  },
  {
    "question": "统计每个门店（store_id）下的客户总数及其中已启用账户（activebool=true）的客户数",
    "sql": "SELECT store_id AS 门店ID, COUNT(*) AS 客户总数, COUNT(*) FILTER (WHERE activebool = true) AS 启用账户数 FROM public.customer GROUP BY store_id ORDER BY store_id;",
    "domain": "客户与账户管理"
  },
  {
    "question": "找出姓氏以字母'S'开头且账户处于启用状态的客户数量，并按姓氏分组汇总",
    "sql": "SELECT last_name AS 姓氏, COUNT(*) AS 客户数量 FROM public.customer WHERE last_name LIKE 'S%' AND activebool = true GROUP BY last_name ORDER BY 客户数量 DESC;",
    "domain": "客户与账户管理"
  },
  {
    "question": "对比分析：统计启用账户（activebool=true）与未启用账户（activebool=false）的客户平均创建年份（取create_date年份），并标注状态",
    "sql": "SELECT CASE WHEN activebool THEN '启用' ELSE '未启用' END AS 账户状态, EXTRACT(YEAR FROM AVG(create_date::timestamp))::INTEGER AS 平均创建年份 FROM public.customer GROUP BY activebool;",
    "domain": "客户与账户管理"
  },
  {
    "question": "查询最近30天内创建的所有客户信息，包括客户ID、姓名、邮箱、所属门店ID及创建日期，按创建时间倒序排列",
    "sql": "SELECT customer_id AS 客户ID, first_name AS 名字, last_name AS 姓氏, email AS 邮箱, store_id AS 门店ID, create_date AS 创建日期 FROM public.customer WHERE create_date >= CURRENT_DATE - INTERVAL '30 days' ORDER BY create_date DESC;",
    "domain": "客户与账户管理"
  },
  {
    "question": "列出所有邮箱域名（@后部分）出现频次超过5次的客户邮箱域及其对应客户数，并按频次降序排列",
    "sql": "SELECT SPLIT_PART(email, '@', 2) AS 邮箱域名, COUNT(*) AS 客户数量 FROM public.customer WHERE email IS NOT NULL GROUP BY SPLIT_PART(email, '@', 2) HAVING COUNT(*) > 5 ORDER BY 客户数量 DESC;",
    "domain": "客户与账户管理"
  },
  {
    "question": "查询每个客户最后更新时间距今的天数，并筛选出超过180天未更新的客户姓名、邮箱及最后更新时间",
    "sql": "SELECT first_name AS 名字, last_name AS 姓氏, email AS 邮箱, last_update AS 最后更新时间, CURRENT_DATE - last_update::date AS 距今未更新天数 FROM public.customer WHERE CURRENT_DATE - last_update::date > 180 ORDER BY 距今未更新天数 DESC;",
    "domain": "客户与账户管理"
  },
  {
    "question": "找出在多个不同门店（store_id）下重复登记的客户姓氏（即同一last_name出现在不同store_id中），并统计其跨门店数量",
    "sql": "SELECT last_name AS 姓氏, COUNT(DISTINCT store_id) AS 关联门店数 FROM public.customer GROUP BY last_name HAVING COUNT(DISTINCT store_id) > 1 ORDER BY 关联门店数 DESC;",
    "domain": "客户与账户管理"
  },
  {
    "question": "获取客户数量最多的前5个姓氏，以及对应客户总数和其中启用账户的比例（保留两位小数）",
    "sql": "SELECT last_name AS 姓氏, COUNT(*) AS 客户总数, ROUND(AVG(CASE WHEN activebool THEN 1.0 ELSE 0.0 END), 2) AS 启用账户比例 FROM public.customer GROUP BY last_name ORDER BY 客户总数 DESC LIMIT 5;",
    "domain": "客户与账户管理"
  },
  {
    "question": "查询所有客户中名字和姓氏长度之和大于20字符的客户信息，包括客户ID、全名（first_name + last_name）、邮箱及地址ID，并按全名长度降序排列",
    "sql": "SELECT customer_id AS 客户ID, CONCAT(first_name, ' ', last_name) AS 全名, email AS 邮箱, address_id AS 地址ID FROM public.customer WHERE LENGTH(first_name) + LENGTH(last_name) > 20 ORDER BY LENGTH(first_name) + LENGTH(last_name) DESC;",
    "domain": "客户与账户管理"
  },
  {
    "question": "列出所有门店及其经理的姓名和邮箱，按门店ID升序排列",
    "sql": "SELECT s.store_id AS 门店编号, st.first_name AS 经理名, st.last_name AS 经理姓氏, st.email AS 经理邮箱 FROM public.store s JOIN public.staff st ON s.manager_staff_id = st.staff_id ORDER BY s.store_id;",
    "domain": "门店与组织架构"
  },
  {
    "question": "统计每个门店的在职员工数量，并仅显示员工数大于1的门店",
    "sql": "SELECT s.store_id AS 门店编号, COUNT(st.staff_id) AS 在职员工数 FROM public.store s JOIN public.staff st ON s.store_id = st.store_id WHERE st.active = true GROUP BY s.store_id HAVING COUNT(st.staff_id) > 1;",
    "domain": "门店与组织架构"
  },
  {
    "question": "找出没有分配经理的门店（即manager_staff_id为NULL）及其地址ID",
    "sql": "SELECT store_id AS 门店编号, address_id AS 地址ID FROM public.store WHERE manager_staff_id IS NULL;",
    "domain": "门店与组织架构"
  },
  {
    "question": "按门店ID汇总各门店员工平均活跃状态（true=1, false=0），保留2位小数",
    "sql": "SELECT s.store_id AS 门店编号, ROUND(AVG(CASE WHEN st.active THEN 1 ELSE 0 END), 2) AS 员工平均活跃度 FROM public.store s JOIN public.staff st ON s.store_id = st.store_id GROUP BY s.store_id ORDER BY s.store_id;",
    "domain": "门店与组织架构"
  },
  {
    "question": "查询所有门店经理的姓名、所属门店ID及最后更新时间，并按更新时间倒序排列取前5条",
    "sql": "SELECT st.first_name AS 经理名, st.last_name AS 经理姓氏, s.store_id AS 门店编号, s.last_update AS 信息更新时间 FROM public.store s JOIN public.staff st ON s.manager_staff_id = st.staff_id ORDER BY s.last_update DESC LIMIT 5;",
    "domain": "门店与组织架构"
  },
  {
    "question": "对比两家门店（ID为1和2）的员工总数与在职员工数，结果包含门店ID、总员工数、在职员工数三列",
    "sql": "SELECT store_id AS 门店编号, COUNT(*) AS 总员工数, COUNT(*) FILTER (WHERE active) AS 在职员工数 FROM public.staff WHERE store_id IN (1, 2) GROUP BY store_id ORDER BY store_id;",
    "domain": "门店与组织架构"
  },
  {
    "question": "列出所有门店ID、对应经理用户名及该经理是否为当前门店唯一员工（即该门店仅此1名员工）",
    "sql": "SELECT s.store_id AS 门店编号, st.username AS 经理用户名, (SELECT COUNT(*) = 1 FROM public.staff st2 WHERE st2.store_id = s.store_id) AS 是否唯一员工 FROM public.store s JOIN public.staff st ON s.manager_staff_id = st.staff_id;",
    "domain": "门店与组织架构"
  },
  {
    "question": "查询每个门店的最新一次员工信息更新时间（取该门店下所有员工last_update的最大值）",
    "sql": "SELECT s.store_id AS 门店编号, MAX(st.last_update) AS 门店员工最新更新时间 FROM public.store s JOIN public.staff st ON s.store_id = st.store_id GROUP BY s.store_id ORDER BY s.store_id;",
    "domain": "门店与组织架构"
  },
  {
    "question": "找出所有既是门店经理又在该门店任职的员工（即manager_staff_id等于staff_id且store_id匹配），返回门店ID、经理姓名和邮箱",
    "sql": "SELECT s.store_id AS 门店编号, st.first_name AS 经理名, st.last_name AS 经理姓氏, st.email AS 经理邮箱 FROM public.store s JOIN public.staff st ON s.manager_staff_id = st.staff_id AND s.store_id = st.store_id;",
    "domain": "门店与组织架构"
  },
  {
    "question": "统计各门店中不同活跃状态（在职/离职）的员工人数分布，结果按门店ID和活跃状态排序",
    "sql": "SELECT s.store_id AS 门店编号, st.active AS 是否在职, COUNT(*) AS 人数 FROM public.store s JOIN public.staff st ON s.store_id = st.store_id GROUP BY s.store_id, st.active ORDER BY s.store_id, st.active;",
    "domain": "门店与组织架构"
  },
  {
    "question": "查询每个国家包含的城市数量，并按城市数量降序排列，只显示前10个国家",
    "sql": "SELECT c.country AS 国家名称, COUNT(ci.city_id) AS 城市数量 FROM public.country c LEFT JOIN public.city ci ON c.country_id = ci.country_id GROUP BY c.country_id, c.country ORDER BY 城市数量 DESC LIMIT 10;",
    "domain": "地理信息管理"
  },
  {
    "question": "找出地址表中邮政编码为空但联系电话不为空的地址记录，并显示其所在城市名和国家名",
    "sql": "SELECT a.address AS 街道地址, ci.city AS 城市名称, co.country AS 国家名称 FROM public.address a JOIN public.city ci ON a.city_id = ci.city_id JOIN public.country co ON ci.country_id = co.country_id WHERE a.postal_code IS NULL OR a.postal_code = '' AND a.phone IS NOT NULL AND a.phone != '';",
    "domain": "地理信息管理"
  },
  {
    "question": "统计每个行政区（district）下的地址数量，仅保留地址数超过5个的行政区，并按数量降序排列",
    "sql": "SELECT district AS 行政区, COUNT(*) AS 地址数量 FROM public.address WHERE district IS NOT NULL AND district != '' GROUP BY district HAVING COUNT(*) > 5 ORDER BY 地址数量 DESC;",
    "domain": "地理信息管理"
  },
  {
    "question": "列出更新时间最早的5个城市及其所属国家名称",
    "sql": "SELECT ci.city AS 城市名称, co.country AS 国家名称, ci.last_update AS 最后更新时间 FROM public.city ci JOIN public.country co ON ci.country_id = co.country_id ORDER BY ci.last_update ASC LIMIT 5;",
    "domain": "地理信息管理"
  },
  {
    "question": "对比中国和美国各自拥有的城市数量，并以‘国家’和‘城市数’两列呈现",
    "sql": "SELECT country AS 国家, COUNT(ci.city_id) AS 城市数 FROM public.country co LEFT JOIN public.city ci ON co.country_id = ci.country_id WHERE co.country IN ('China', 'United States') GROUP BY co.country;",
    "domain": "地理信息管理"
  },
  {
    "question": "查询所有位于‘Alberta’行政区的地址，并关联显示其城市名与国家名，按地址ID升序排列",
    "sql": "SELECT a.address_id AS 地址ID, a.address AS 街道地址, ci.city AS 城市名称, co.country AS 国家名称 FROM public.address a JOIN public.city ci ON a.city_id = ci.city_id JOIN public.country co ON ci.country_id = co.country_id WHERE a.district = 'Alberta' ORDER BY a.address_id ASC;",
    "domain": "地理信息管理"
  },
  {
    "question": "找出拥有最多地址记录的城市TOP5（需显示城市名、国家名及地址总数）",
    "sql": "SELECT ci.city AS 城市名称, co.country AS 国家名称, COUNT(a.address_id) AS 地址总数 FROM public.city ci JOIN public.country co ON ci.country_id = co.country_id JOIN public.address a ON ci.city_id = a.city_id GROUP BY ci.city_id, ci.city, co.country ORDER BY 地址总数 DESC LIMIT 5;",
    "domain": "地理信息管理"
  },
  {
    "question": "统计2006年2月15日当天被更新过的国家、城市和地址记录总数（分别计数并合并为一行结果）",
    "sql": "SELECT (SELECT COUNT(*) FROM public.country WHERE DATE(last_update) = '2006-02-15') AS 国家更新数, (SELECT COUNT(*) FROM public.city WHERE DATE(last_update) = '2006-02-15') AS 城市更新数, (SELECT COUNT(*) FROM public.address WHERE DATE(last_update) = '2006-02-15') AS 地址更新数;",
    "domain": "地理信息管理"
  },
  {
    "question": "查询所有城市名称中包含括号（如‘(La Corua)’）的城市及其所属国家，按国家名升序、城市名降序排列",
    "sql": "SELECT ci.city AS 城市名称, co.country AS 国家名称 FROM public.city ci JOIN public.country co ON ci.country_id = co.country_id WHERE ci.city LIKE '%(%)%' ORDER BY co.country ASC, ci.city DESC;",
    "domain": "地理信息管理"
  },
  {
    "question": "列出至少有3个不同行政区（district）的城市名称及对应国家名",
    "sql": "SELECT ci.city AS 城市名称, co.country AS 国家名称 FROM public.city ci JOIN public.country co ON ci.country_id = co.country_id JOIN public.address a ON ci.city_id = a.city_id GROUP BY ci.city_id, ci.city, co.country HAVING COUNT(DISTINCT a.district) >= 3;",
    "domain": "地理信息管理"
  },
  {
    "question": "查询所有电影的标题、上映年份、时长和租赁单价，并按上映年份降序、时长升序排列",
    "sql": "SELECT title AS 标题, release_year AS 上映年份, length AS 时长分钟, rental_rate AS 租赁单价 FROM public.film ORDER BY release_year DESC, length ASC;",
    "domain": "影片内容资产"
  },
  {
    "question": "统计每种电影分级（rating）的影片数量，并仅显示影片数超过50部的分级",
    "sql": "SELECT rating AS 分级, COUNT(*) AS 影片数量 FROM public.film GROUP BY rating HAVING COUNT(*) > 50 ORDER BY 影片数量 DESC;",
    "domain": "影片内容资产"
  },
  {
    "question": "找出租赁单价最高和最低的三部电影，分别显示标题、分级、租赁单价和赔偿成本",
    "sql": "SELECT title AS 标题, rating AS 分级, rental_rate AS 租赁单价, replacement_cost AS 赔偿成本 FROM public.film ORDER BY rental_rate DESC LIMIT 3 UNION ALL SELECT title AS 标题, rating AS 分级, rental_rate AS 租赁单价, replacement_cost AS 赔偿成本 FROM public.film ORDER BY rental_rate ASC LIMIT 3;",
    "domain": "影片内容资产"
  },
  {
    "question": "计算所有电影的平均时长、平均租赁单价、平均赔偿成本，并统计总影片数",
    "sql": "SELECT ROUND(AVG(length), 2) AS 平均时长分钟, ROUND(AVG(rental_rate), 2) AS 平均租赁单价, ROUND(AVG(replacement_cost), 2) AS 平均赔偿成本, COUNT(*) AS 总影片数 FROM public.film;",
    "domain": "影片内容资产"
  },
  {
    "question": "列出所有英文原声（language_id = 1）且评级为PG-13的电影，显示标题、描述前100字符、上映年份和租赁天数",
    "sql": "SELECT title AS 标题, SUBSTRING(description, 1, 100) AS 描述摘要, release_year AS 上映年份, rental_duration AS 租赁天数 FROM public.film WHERE language_id = 1 AND rating = 'PG-13';",
    "domain": "影片内容资产"
  },
  {
    "question": "按语言名称统计影片数量（需关联language表），并按数量降序排列",
    "sql": "SELECT l.name AS 语言名称, COUNT(f.film_id) AS 影片数量 FROM public.film f JOIN public.language l ON f.language_id = l.language_id GROUP BY l.name ORDER BY 影片数量 DESC;",
    "domain": "影片内容资产"
  },
  {
    "question": "查找描述中包含'robot'或'battle'关键词（不区分大小写）的电影，返回标题、分级、时长和语言名称",
    "sql": "SELECT f.title AS 标题, f.rating AS 分级, f.length AS 时长分钟, l.name AS 语言名称 FROM public.film f JOIN public.language l ON f.language_id = l.language_id WHERE LOWER(f.description) LIKE '%robot%' OR LOWER(f.description) LIKE '%battle%';",
    "domain": "影片内容资产"
  },
  {
    "question": "分析各上映年份的平均赔偿成本趋势：显示年份、该年影片数、平均赔偿成本（保留两位小数），仅限2000年及以后的影片",
    "sql": "SELECT release_year AS 上映年份, COUNT(*) AS 影片数, ROUND(AVG(replacement_cost), 2) AS 平均赔偿成本 FROM public.film WHERE release_year >= 2000 GROUP BY release_year ORDER BY 上映年份;",
    "domain": "影片内容资产"
  },
  {
    "question": "找出拥有最多特别花絮（special_features数组长度最大）的前5部电影，显示标题、分级、花絮数量及租赁单价",
    "sql": "SELECT title AS 标题, rating AS 分级, ARRAY_LENGTH(special_features, 1) AS 花絮数量, rental_rate AS 租赁单价 FROM public.film WHERE special_features IS NOT NULL ORDER BY ARRAY_LENGTH(special_features, 1) DESC LIMIT 5;",
    "domain": "影片内容资产"
  },
  {
    "question": "对比PG级与R级电影的租赁单价和赔偿成本差异：分别计算两类影片的平均租赁单价和平均赔偿成本",
    "sql": "SELECT rating AS 分级, ROUND(AVG(rental_rate), 2) AS 平均租赁单价, ROUND(AVG(replacement_cost), 2) AS 平均赔偿成本 FROM public.film WHERE rating IN ('PG', 'R') GROUP BY rating;",
    "domain": "影片内容资产"
  },
  {
    "question": "列出所有电影分类及其对应的影片数量，按影片数量降序排列",
    "sql": "SELECT c.name AS 分类名称, COUNT(fc.film_id) AS 影片数量 FROM public.category c LEFT JOIN public.film_category fc ON c.category_id = fc.category_id GROUP BY c.category_id, c.name ORDER BY 影片数量 DESC;",
    "domain": "内容分类与演职人员"
  },
  {
    "question": "查询参演影片最多的前5位演员姓名（全名）及参演影片数",
    "sql": "SELECT a.first_name || ' ' || a.last_name AS 演员全名, COUNT(fa.film_id) AS 参演影片数 FROM public.actor a INNER JOIN public.film_actor fa ON a.actor_id = fa.actor_id GROUP BY a.actor_id, a.first_name, a.last_name ORDER BY 参演影片数 DESC LIMIT 5;",
    "domain": "内容分类与演职人员"
  },
  {
    "question": "找出同时属于‘Action’和‘Sci-Fi’两个分类的所有影片标题（需关联film表获取title）",
    "sql": "SELECT f.title AS 影片标题 FROM public.film f INNER JOIN public.film_category fc1 ON f.film_id = fc1.film_id INNER JOIN public.film_category fc2 ON f.film_id = fc2.film_id INNER JOIN public.category c1 ON fc1.category_id = c1.category_id INNER JOIN public.category c2 ON fc2.category_id = c2.category_id WHERE c1.name = 'Action' AND c2.name = 'Sci-Fi';",
    "domain": "内容分类与演职人员"
  },
  {
    "question": "统计每个分类下平均影片时长（length字段在film表中），仅显示平均时长超过100分钟的分类",
    "sql": "SELECT c.name AS 分类名称, ROUND(AVG(f.length), 2) AS 平均时长_分钟 FROM public.category c INNER JOIN public.film_category fc ON c.category_id = fc.category_id INNER JOIN public.film f ON fc.film_id = f.film_id GROUP BY c.category_id, c.name HAVING AVG(f.length) > 100 ORDER BY 平均时长_分钟 DESC;",
    "domain": "内容分类与演职人员"
  },
  {
    "question": "查询姓氏为‘Wahlberg’的演员参演的所有影片名称及所属分类名称",
    "sql": "SELECT a.first_name AS 演员名, a.last_name AS 演员姓氏, f.title AS 影片名称, c.name AS 分类名称 FROM public.actor a INNER JOIN public.film_actor fa ON a.actor_id = fa.actor_id INNER JOIN public.film f ON fa.film_id = f.film_id INNER JOIN public.film_category fc ON f.film_id = fc.film_id INNER JOIN public.category c ON fc.category_id = c.category_id WHERE a.last_name = 'Wahlberg';",
    "domain": "内容分类与演职人员"
  },
  {
    "question": "对比‘Animation’和‘Children’两个分类的影片数量差异（输出分类名与数量，并标注差异值）",
    "sql": "WITH cat_counts AS (SELECT c.name, COUNT(fc.film_id) AS cnt FROM public.category c INNER JOIN public.film_category fc ON c.category_id = fc.category_id WHERE c.name IN ('Animation', 'Children') GROUP BY c.name) SELECT name AS 分类名称, cnt AS 影片数量, (SELECT cnt FROM cat_counts WHERE name = 'Animation') - (SELECT cnt FROM cat_counts WHERE name = 'Children') AS 数量差异 FROM cat_counts;",
    "domain": "内容分类与演职人员"
  },
  {
    "question": "找出从未被归类到任何分类中的影片（即film表中存在但film_category中无记录的film_id）",
    "sql": "SELECT f.film_id AS 影片ID, f.title AS 影片标题 FROM public.film f LEFT JOIN public.film_category fc ON f.film_id = fc.film_id WHERE fc.film_id IS NULL;",
    "domain": "内容分类与演职人员"
  },
  {
    "question": "列出所有演员及其参演影片数，若未参演任何影片则显示0",
    "sql": "SELECT a.actor_id AS 演员ID, a.first_name AS 名字, a.last_name AS 姓氏, COALESCE(COUNT(fa.film_id), 0) AS 参演影片数 FROM public.actor a LEFT JOIN public.film_actor fa ON a.actor_id = fa.actor_id GROUP BY a.actor_id, a.first_name, a.last_name ORDER BY 参演影片数 DESC;",
    "domain": "内容分类与演职人员"
  },
  {
    "question": "查询2006年2月15日当天新增或更新的分类-影片关联记录总数及对应分类名称列表",
    "sql": "SELECT COUNT(*) AS 关联更新总数, STRING_AGG(DISTINCT c.name, ', ') AS 涉及分类 FROM public.film_category fc INNER JOIN public.category c ON fc.category_id = c.category_id WHERE DATE(fc.last_update) = '2006-02-15';",
    "domain": "内容分类与演职人员"
  },
  {
    "question": "找出至少参演了3部‘Comedy’分类影片的演员全名及对应影片数",
    "sql": "SELECT a.first_name || ' ' || a.last_name AS 演员全名, COUNT(*) AS 喜剧影片数 FROM public.actor a INNER JOIN public.film_actor fa ON a.actor_id = fa.actor_id INNER JOIN public.film_category fc ON fa.film_id = fc.film_id INNER JOIN public.category c ON fc.category_id = c.category_id WHERE c.name = 'Comedy' GROUP BY a.actor_id, a.first_name, a.last_name HAVING COUNT(*) >= 3 ORDER BY 喜剧影片数 DESC;",
    "domain": "内容分类与演职人员"
  },
  {
    "question": "查询近30天内所有已完成归还的租赁记录，按租赁时间倒序排列，显示租赁ID、客户ID、归还日期和经办员工ID",
    "sql": "SELECT rental_id AS 租赁ID, customer_id AS 客户ID, return_date AS 归还日期, staff_id AS 经办员工ID FROM public.rental WHERE return_date IS NOT NULL AND rental_date >= CURRENT_DATE - INTERVAL '30 days' ORDER BY rental_date DESC;",
    "domain": "租赁交易与履约"
  },
  {
    "question": "统计每个门店（通过inventory关联）的总租赁次数，并按次数降序排列，显示门店ID和租赁次数",
    "sql": "SELECT i.store_id AS 门店ID, COUNT(r.rental_id) AS 租赁次数 FROM public.rental r JOIN public.inventory i ON r.inventory_id = i.inventory_id GROUP BY i.store_id ORDER BY 租赁次数 DESC;",
    "domain": "租赁交易与履约"
  },
  {
    "question": "找出租赁次数最多的前5位客户，显示客户ID、姓名（来自customer表）及租赁总次数",
    "sql": "SELECT c.customer_id AS 客户ID, CONCAT(c.first_name, ' ', c.last_name) AS 姓名, COUNT(r.rental_id) AS 租赁总次数 FROM public.rental r JOIN public.customer c ON r.customer_id = c.customer_id GROUP BY c.customer_id, c.first_name, c.last_name ORDER BY 租赁总次数 DESC LIMIT 5;",
    "domain": "租赁交易与履约"
  },
  {
    "question": "分析各月份的租赁发起量与归还量对比：统计每月租赁数（rental_date）、已归还数（return_date非空），要求月份格式为'YYYY-MM'，结果按月份升序排列",
    "sql": "SELECT TO_CHAR(rental_date, 'YYYY-MM') AS 年月, COUNT(*) AS 租赁数, COUNT(return_date) AS 归还数 FROM public.rental GROUP BY TO_CHAR(rental_date, 'YYYY-MM') ORDER BY 年月;",
    "domain": "租赁交易与履约"
  },
  {
    "question": "查询尚未归还（return_date为空）且租赁已超过7天的所有租赁记录，显示租赁ID、客户姓名、影片标题（需联查inventory→film）、租赁日期",
    "sql": "SELECT r.rental_id AS 租赁ID, CONCAT(c.first_name, ' ', c.last_name) AS 客户姓名, f.title AS 影片标题, r.rental_date AS 租赁日期 FROM public.rental r JOIN public.customer c ON r.customer_id = c.customer_id JOIN public.inventory i ON r.inventory_id = i.inventory_id JOIN public.film f ON i.film_id = f.film_id WHERE r.return_date IS NULL AND r.rental_date <= CURRENT_DATE - INTERVAL '7 days';",
    "domain": "租赁交易与履约"
  },
  {
    "question": "统计每位员工处理的租赁订单总数及平均每日处理量（按rental_date所在日计算），仅包含有至少10单的员工，结果按总数降序",
    "sql": "SELECT s.staff_id AS 员工ID, COUNT(r.rental_id) AS 订单总数, ROUND(COUNT(r.rental_id)::NUMERIC / COUNT(DISTINCT DATE(r.rental_date)), 2) AS 平均每日处理量 FROM public.rental r JOIN public.staff s ON r.staff_id = s.staff_id GROUP BY s.staff_id HAVING COUNT(r.rental_id) >= 10 ORDER BY 订单总数 DESC;",
    "domain": "租赁交易与履约"
  },
  {
    "question": "找出被租赁次数最多的前3部影片（通过inventory和film关联），显示影片ID、标题、租赁总次数",
    "sql": "SELECT f.film_id AS 影片ID, f.title AS 影片标题, COUNT(r.rental_id) AS 租赁总次数 FROM public.rental r JOIN public.inventory i ON r.inventory_id = i.inventory_id JOIN public.film f ON i.film_id = f.film_id GROUP BY f.film_id, f.title ORDER BY 租赁总次数 DESC LIMIT 3;",
    "domain": "租赁交易与履约"
  },
  {
    "question": "对比两个指定门店（store_id=1和store_id=2）的租赁活跃度：分别统计其租赁总次数、平均单次租赁时长（单位：天，return_date - rental_date），要求结果在同一行展示",
    "sql": "SELECT SUM(CASE WHEN i.store_id = 1 THEN 1 ELSE 0 END) AS 门店1租赁次数, ROUND(AVG(CASE WHEN i.store_id = 1 THEN EXTRACT(EPOCH FROM (r.return_date - r.rental_date))/86400 END), 2) AS 门店1平均租赁天数, SUM(CASE WHEN i.store_id = 2 THEN 1 ELSE 0 END) AS 门店2租赁次数, ROUND(AVG(CASE WHEN i.store_id = 2 THEN EXTRACT(EPOCH FROM (r.return_date - r.rental_date))/86400 END), 2) AS 门店2平均租赁天数 FROM public.rental r JOIN public.inventory i ON r.inventory_id = i.inventory_id WHERE i.store_id IN (1, 2);",
    "domain": "租赁交易与履约"
  },
  {
    "question": "查询每个客户最近一次租赁的完整信息（含租赁ID、影片标题、门店ID、租赁日期、归还日期），按客户ID升序排列",
    "sql": "SELECT r.customer_id AS 客户ID, r.rental_id AS 租赁ID, f.title AS 影片标题, i.store_id AS 门店ID, r.rental_date AS 租赁日期, r.return_date AS 归还日期 FROM public.rental r JOIN public.inventory i ON r.inventory_id = i.inventory_id JOIN public.film f ON i.film_id = f.film_id WHERE (r.customer_id, r.rental_date) IN (SELECT customer_id, MAX(rental_date) FROM public.rental GROUP BY customer_id) ORDER BY r.customer_id;",
    "domain": "租赁交易与履约"
  },
  {
    "question": "识别存在异常租赁行为的客户：租赁次数≥5且平均租赁周期（return_date - rental_date）超过30天的客户，显示客户ID、姓名、租赁次数、平均租赁天数",
    "sql": "SELECT c.customer_id AS 客户ID, CONCAT(c.first_name, ' ', c.last_name) AS 姓名, COUNT(r.rental_id) AS 租赁次数, ROUND(AVG(EXTRACT(EPOCH FROM (r.return_date - r.rental_date))/86400), 2) AS 平均租赁天数 FROM public.rental r JOIN public.customer c ON r.customer_id = c.customer_id WHERE r.return_date IS NOT NULL GROUP BY c.customer_id, c.first_name, c.last_name HAVING COUNT(r.rental_id) >= 5 AND AVG(EXTRACT(EPOCH FROM (r.return_date - r.rental_date))/86400) > 30.0 ORDER BY 平均租赁天数 DESC;",
    "domain": "租赁交易与履约"
  },
  {
    "question": "查询2007年2月的每日总收款金额，并按日期升序排列",
    "sql": "SELECT DATE(payment_date) AS 日期, SUM(amount) AS 日收款总额 FROM public.payment WHERE payment_date >= '2007-02-01' AND payment_date < '2007-03-01' GROUP BY DATE(payment_date) ORDER BY 日期 ASC;",
    "domain": "财务结算"
  },
  {
    "question": "列出收款金额最高的前5位员工姓名及其对应总收款额",
    "sql": "SELECT s.first_name || ' ' || s.last_name AS 员工姓名, SUM(p.amount) AS 总收款额 FROM public.payment p JOIN public.staff s ON p.staff_id = s.staff_id GROUP BY s.staff_id, s.first_name, s.last_name ORDER BY 总收款额 DESC LIMIT 5;",
    "domain": "财务结算"
  },
  {
    "question": "统计每位客户累计支付金额，仅显示总额超过100元的客户及对应金额",
    "sql": "SELECT c.customer_id AS 客户ID, c.first_name || ' ' || c.last_name AS 客户姓名, SUM(p.amount) AS 累计支付金额 FROM public.payment p JOIN public.customer c ON p.customer_id = c.customer_id GROUP BY c.customer_id, c.first_name, c.last_name HAVING SUM(p.amount) > 100 ORDER BY 累计支付金额 DESC;",
    "domain": "财务结算"
  },
  {
    "question": "查询所有在周末（周六或周日）发生的支付记录，返回客户姓名、员工姓名、支付金额和支付时间",
    "sql": "SELECT c.first_name || ' ' || c.last_name AS 客户姓名, s.first_name || ' ' || s.last_name AS 员工姓名, p.amount AS 支付金额, p.payment_date AS 支付时间 FROM public.payment p JOIN public.customer c ON p.customer_id = c.customer_id JOIN public.staff s ON p.staff_id = s.staff_id WHERE EXTRACT(ISODOW FROM p.payment_date) IN (0, 6);",
    "domain": "财务结算"
  },
  {
    "question": "对比2006年与2007年各季度总收款金额，输出年份、季度、总金额",
    "sql": "SELECT EXTRACT(YEAR FROM payment_date) AS 年份, EXTRACT(QUARTER FROM payment_date) AS 季度, SUM(amount) AS 总收款金额 FROM public.payment WHERE EXTRACT(YEAR FROM payment_date) IN (2006, 2007) GROUP BY EXTRACT(YEAR FROM payment_date), EXTRACT(QUARTER FROM payment_date) ORDER BY 年份, 季度;",
    "domain": "财务结算"
  },
  {
    "question": "找出单笔支付金额大于9.99元的所有记录，按金额降序排列并显示客户邮箱、支付金额和时间",
    "sql": "SELECT c.email AS 客户邮箱, p.amount AS 支付金额, p.payment_date AS 支付时间 FROM public.payment p JOIN public.customer c ON p.customer_id = c.customer_id WHERE p.amount > 9.99 ORDER BY p.amount DESC;",
    "domain": "财务结算"
  },
  {
    "question": "计算每位员工平均单笔收款金额，并筛选出平均值高于5元的员工及其平均值",
    "sql": "SELECT s.first_name || ' ' || s.last_name AS 员工姓名, ROUND(AVG(p.amount), 2) AS 平均单笔收款金额 FROM public.payment p JOIN public.staff s ON p.staff_id = s.staff_id GROUP BY s.staff_id, s.first_name, s.last_name HAVING AVG(p.amount) > 5 ORDER BY 平均单笔收款金额 DESC;",
    "domain": "财务结算"
  },
  {
    "question": "统计每月支付次数与总金额，并标记是否为当月最高收款月（基于总金额）",
    "sql": "WITH monthly_stats AS (SELECT EXTRACT(YEAR FROM payment_date) AS 年, EXTRACT(MONTH FROM payment_date) AS 月, COUNT(*) AS 支付次数, SUM(amount) AS 总金额 FROM public.payment GROUP BY EXTRACT(YEAR FROM payment_date), EXTRACT(MONTH FROM payment_date)), max_month AS (SELECT MAX(总金额) AS max_amt FROM monthly_stats) SELECT ms.年, ms.月, ms.支付次数, ms.总金额, CASE WHEN ms.总金额 = mm.max_amt THEN '是' ELSE '否' END AS 是否最高收款月 FROM monthly_stats ms CROSS JOIN max_month mm ORDER BY ms.总金额 DESC;",
    "domain": "财务结算"
  },
  {
    "question": "查询客户ID为341的所有支付明细，包括租赁ID、支付金额、支付时间及对应员工姓名",
    "sql": "SELECT p.rental_id AS 租赁ID, p.amount AS 支付金额, p.payment_date AS 支付时间, s.first_name || ' ' || s.last_name AS 处理员工 FROM public.payment p JOIN public.staff s ON p.staff_id = s.staff_id WHERE p.customer_id = 341 ORDER BY p.payment_date DESC;",
    "domain": "财务结算"
  },
  {
    "question": "分析不同员工处理的支付中，金额分布区间（<3元、3-6元、>6元）的笔数占比",
    "sql": "SELECT s.first_name || ' ' || s.last_name AS 员工姓名, COUNT(*) FILTER (WHERE p.amount < 3) AS 小于3元笔数, COUNT(*) FILTER (WHERE p.amount BETWEEN 3 AND 6) AS 3至6元笔数, COUNT(*) FILTER (WHERE p.amount > 6) AS 大于6元笔数, ROUND(100.0 * COUNT(*) FILTER (WHERE p.amount < 3) / NULLIF(COUNT(*), 0), 2) AS 小于3元占比, ROUND(100.0 * COUNT(*) FILTER (WHERE p.amount BETWEEN 3 AND 6) / NULLIF(COUNT(*), 0), 2) AS 3至6元占比, ROUND(100.0 * COUNT(*) FILTER (WHERE p.amount > 6) / NULLIF(COUNT(*), 0), 2) AS 大于6元占比 FROM public.payment p JOIN public.staff s ON p.staff_id = s.staff_id GROUP BY s.staff_id, s.first_name, s.last_name ORDER BY 员工姓名;",
    "domain": "财务结算"
  }
]